#!/usr/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

source "$SCRIPT_DIR/lib/pkg-manual.sh"
source "$SCRIPT_DIR/lib/setup-ui.sh"

usage() {
  cat <<EOF
Usage: $(basename "$0") <command> [args]

Track manually installed Termux packages and opt them into chezmoi install.

Commands:
  scan                 Add newly seen manual packages as pending (never removes)
  list [status]        List tracked packages (optional: pending|install|ignore)
  review               Interactively mark pending packages install or ignore
  mark <pkg> <status>  Set status: pending, install, or ignore
  status               Summary counts

Managed packages (packages.yaml termux.pkg, profiles) and packages already in
$(basename "${PKG_MANUAL_FILE:-home/.chezmoidata/pkg-manual.yaml}") are skipped on scan.
Packages with status install are appended to chezmoi apt install on apply (Termux).
EOF
}

cmd_scan() {
  pkg_manual_load
  local added=0 pkg
  while IFS= read -r pkg; do
    [[ -z "$pkg" ]] && continue
    if pkg_manual_add_pending "$pkg"; then
      echo "NEW pending: $pkg"
      ((added++)) || true
    fi
  done < <(pkg_manual_find_new_packages)

  pkg_manual_save
  if ((added == 0)); then
    echo "No new manual packages to track."
  else
    echo "Added $added package(s) as pending. Run: $(basename "$0") review"
  fi
}

cmd_list() {
  local filter="${1:-}"
  pkg_manual_load
  local pkg status
  for pkg in $(printf '%s\n' "${!PKG_MANUAL_STATUS[@]}" | sort); do
    status="${PKG_MANUAL_STATUS[$pkg]}"
    [[ -n "$filter" && "$status" != "$filter" ]] && continue
    printf '%-40s %s  (%s)\n' "$pkg" "$status" "${PKG_MANUAL_FIRST_SEEN[$pkg]}"
  done
}

cmd_mark() {
  local pkg="${1:-}" status="${2:-}"
  if [[ -z "$pkg" || -z "$status" ]]; then
    echo "Usage: $(basename "$0") mark <pkg> <pending|install|ignore>" >&2
    exit 1
  fi
  pkg_manual_load
  if [[ -z "${PKG_MANUAL_STATUS[$pkg]:-}" ]]; then
    pkg_manual_set_status "$pkg" "$status"
    echo "Added $pkg as $status"
  else
    pkg_manual_set_status "$pkg" "$status"
    echo "Updated $pkg → $status"
  fi
  pkg_manual_save
}

cmd_review() {
  pkg_manual_load
  local pending=() pkg choice
  for pkg in $(printf '%s\n' "${!PKG_MANUAL_STATUS[@]}" | sort); do
    [[ "${PKG_MANUAL_STATUS[$pkg]}" == "pending" ]] && pending+=("$pkg")
  done

  if ((${#pending[@]} == 0)); then
    echo "No pending packages to review."
    return 0
  fi

  echo "Review ${#pending[@]} pending package(s)."
  for pkg in "${pending[@]}"; do
    echo
    echo "Package: $pkg"
    if command -v gum >/dev/null 2>&1; then
      choice="$(gum choose --header "Action for $pkg" install ignore "keep pending")"
    else
      PS3="Action for $pkg: "
      select choice in install ignore "keep pending"; do
        [[ -n "$choice" ]] && break
      done
    fi
    case "$choice" in
      install|ignore) pkg_manual_set_status "$pkg" "$choice" ;;
      "keep pending") ;;
      *) echo "Skipping $pkg" ;;
    esac
  done
  pkg_manual_save
  echo "Review complete."
}

cmd_status() {
  pkg_manual_load
  printf 'pending: %s\n' "$(pkg_manual_count_by_status pending)"
  printf 'install: %s\n' "$(pkg_manual_count_by_status install)"
  printf 'ignore:  %s\n' "$(pkg_manual_count_by_status ignore)"
  printf 'file:    %s\n' "$PKG_MANUAL_FILE"
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    scan) shift; cmd_scan "$@" ;;
    list) shift; cmd_list "$@" ;;
    review) shift; cmd_review "$@" ;;
    mark) shift; cmd_mark "$@" ;;
    status) shift; cmd_status "$@" ;;
    -h|--help|help|"") usage ;;
    *) echo "Unknown command: $cmd" >&2; usage >&2; exit 1 ;;
  esac
}

main "$@"
