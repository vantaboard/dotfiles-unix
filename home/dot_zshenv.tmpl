#!/usr/bin/bash

function adjust_webcam() {
    if [[ $1 == 'exposure' ]]; then
        cameractrls2 -d "/dev/video2" -s exposure_time_absolute,50,800
        return;
    fi

    cameractrls -d "/dev/video2" -c "auto_exposure=manual_mode,exposure_time_absolute=200,backlight_compensation=1,white_balance_automatic=0,white_balance_temperature=2800"
}

function webcam() {
    adjust_webcam "$1"
}

DEBIAN_PREVENT_KEYBOARD_CHANGES=yes
[[ -f "$HOME/.cargo/env" ]] && . "$HOME/.cargo/env"

{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "mise" }}
if command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
{{- end }}
{{- if index $f "direnv" }}
eval "$(direnv hook zsh)"

# Non-interactive shells (Cursor agent, scripts, IDE-spawned commands) don't
# draw a prompt and aren't always entered via `cd`, so neither direnv's
# `precmd` nor `chpwd` hooks fire. Force a one-shot evaluation against the
# spawn-time CWD so `.envrc`-supplied PATH and env vars are available to those
# shells too. The `direnv allow` whitelist still applies, so the security
# model is unchanged.
if [[ ! -o interactive ]] && command -v direnv >/dev/null 2>&1; then
    eval "$(direnv export zsh 2>/dev/null)"
fi
{{- end }}

