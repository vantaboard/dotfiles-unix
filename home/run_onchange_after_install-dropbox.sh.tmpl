{{ if and (eq .chezmoi.os "linux") -}}
{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "dropbox" -}}
#!/bin/bash
set -euo pipefail

# hash: dropbox-v1

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping dropbox install"
  exit 0
fi

if command -v dropbox >/dev/null 2>&1 || dpkg-query -W -f='${Status}' dropbox 2>/dev/null | grep -q 'install ok installed'; then
  if command -v dropbox >/dev/null 2>&1; then
    echo "dropbox already installed: $(dropbox version 2>/dev/null || dropbox status 2>/dev/null || echo installed)"
  else
    echo "dropbox package already installed"
  fi
  exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "WARN: curl not found; skipping dropbox install"
  exit 0
fi

arch="$(dpkg --print-architecture 2>/dev/null || uname -m)"
case "$arch" in
  amd64|x86_64) deb_arch=amd64 ;;
  *)
    echo "WARN: Dropbox Linux package is amd64-only; skipping (arch=$arch)"
    exit 0
    ;;
esac

echo "Resolving latest Dropbox package for Ubuntu..."
deb_name="$(
  curl -fsSL "https://linux.dropbox.com/packages/ubuntu/" \
    | grep -oE "dropbox_[0-9]{4}\.[0-9]{2}\.[0-9]{2}_${deb_arch}\\.deb" \
    | sort -V \
    | tail -1
)"
if [[ -z "$deb_name" ]]; then
  echo "WARN: could not resolve Dropbox .deb from linux.dropbox.com; skipping"
  exit 0
fi

deb_url="https://linux.dropbox.com/packages/ubuntu/${deb_name}"
tmpdir="$(mktemp -d)"
trap 'rm -rf "$tmpdir"' EXIT
deb_path="$tmpdir/$deb_name"

echo "Downloading $deb_name..."
curl -fsSL "$deb_url" -o "$deb_path"

echo "Installing Dropbox..."
export DEBIAN_FRONTEND=noninteractive
sudo apt install -y -qq "$deb_path"

if command -v dropbox >/dev/null 2>&1; then
  echo "dropbox installed: $(dropbox version 2>/dev/null || echo "$deb_name")"
else
  echo "dropbox installed: $deb_name"
fi

cat <<'EOF'

Dropbox is installed. Link your account:
  Desktop:  dropbox start
            (or launch Dropbox from Applications)
  Headless: dropbox start -i
            (copy the URL into a browser on another device)

Manage sync from ~/Dropbox:
  dropbox status
  dropbox exclude add <directory>
  dropbox exclude list

See: https://help.dropbox.com/installs/linux-commands
EOF
{{- end -}}
{{ end -}}
