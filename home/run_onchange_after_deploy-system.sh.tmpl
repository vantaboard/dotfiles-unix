{{ if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $deploy := $p.system_deploy | default list }}

SOURCE="{{ .chezmoi.sourceDir }}/system"

# hash: {{ $deploy | toYaml | sha256sum }}
# hash: {{ include "system/bin/sway-session" | sha256sum }}
# hash: {{ include "system/gdm3/custom.conf" | sha256sum }}
# hash: {{ include "system/wayland-sessions/sway.desktop" | sha256sum }}
# hash: {{ include "system/grub/default" | sha256sum }}
# hash: {{ include "system/keyd/default.conf" | sha256sum }}
# hash: {{ include "system/libinput/local-overrides.quirks.tmpl" | sha256sum }}
# hash: {{ include "system/ssh/sshd_config.d/99-keyonly-port.conf" | sha256sum }}
# hash: {{ include "system/ssh/ssh.socket.d/port.conf" | sha256sum }}
# hash: {{ include "system/systemd-sleep/displays-resume.tmpl" | sha256sum }}
# hash: {{ include "system/modprobe.d/nvidia-s0ix.conf" | sha256sum }}
# hash: {{ include "system/systemd/logind.conf.d/ignore-lid-switch.conf" | sha256sum }}
# hash: {{ include "system/systemd/llama-swap.service.tmpl" | sha256sum }}

deploy_file() {
  local src="$1"
  local dest="$2"
  local mode="${3:-644}"
  sudo install -Dm"$mode" "$src" "$dest"
}

deploy_dir_file() {
  local src="$1"
  local dest="$2"
  local mode="${3:-644}"
  sudo install -d "$(dirname "$dest")"
  sudo install -m"$mode" "$src" "$dest"
}

if [[ "${CHEZMOI_SKIP_SYSTEM_DEPLOY:-}" == "1" ]]; then
  echo "CHEZMOI_SKIP_SYSTEM_DEPLOY=1; skipping system deploy"
  exit 0
fi

has_deploy() {
  local key="$1"
{{- if $deploy }}
  case "$key" in
{{- range $deploy }}
    {{ . }}) return 0 ;;
{{- end }}
  esac
  return 1
{{- else }}
  return 0
{{- end }}
}

if has_deploy displays_resume && command -v systemctl >/dev/null 2>&1; then
  TMP_SLEEP="$(mktemp)"
  chezmoi execute-template < "$SOURCE/systemd-sleep/displays-resume.tmpl" > "$TMP_SLEEP"
  deploy_file "$TMP_SLEEP" /usr/lib/systemd/system-sleep/displays-resume 755
  rm -f "$TMP_SLEEP"
  # Retire the old sleep.target unit — its ExecStop never ran on wake and the user
  # copy referenced a non-existent user sleep.target.
  sudo systemctl disable --now displays-resume.service 2>/dev/null || true
  sudo rm -f /etc/systemd/system/displays-resume.service
  sudo systemctl daemon-reload 2>/dev/null || true
  # autorandr (xrandr/X11) fights kanshi on sway Wayland and broke dock replug recovery.
  sudo systemctl unmask autorandr.service 2>/dev/null || true
  sudo systemctl disable --now autorandr-lid-listener.service 2>/dev/null || true
  if dpkg-query -W -f='${Status}' autorandr 2>/dev/null | grep -q 'install ok installed'; then
    sudo apt-get remove -y --purge autorandr
  fi
  # NVIDIA + s2idle: without S0ix power management, VRAM restore is broken on
  # wake and sway cannot light up any output (see the conf file for details).
  # The nvidia modules are baked into the initramfs, so a rebuild is needed
  # for the option to take effect at boot.
  if [[ -d /etc/modprobe.d && -d /proc/driver/nvidia ]]; then
    if ! cmp -s "$SOURCE/modprobe.d/nvidia-s0ix.conf" /etc/modprobe.d/nvidia-s0ix.conf; then
      deploy_file "$SOURCE/modprobe.d/nvidia-s0ix.conf" /etc/modprobe.d/nvidia-s0ix.conf
      if command -v update-initramfs >/dev/null 2>&1; then
        sudo update-initramfs -u
      fi
      echo "NVIDIA S0ix power management enabled; reboot for suspend/resume fix"
    fi
  fi
fi

if has_deploy sway_session; then
  deploy_file "$SOURCE/bin/sway-session" /usr/local/bin/sway-session 755
  deploy_file "$SOURCE/wayland-sessions/sway.desktop" /usr/share/wayland-sessions/sway.desktop
  deploy_dir_file "$SOURCE/systemd/logind.conf.d/ignore-lid-switch.conf" \
    /etc/systemd/logind.conf.d/ignore-lid-switch.conf
  sudo systemctl reload systemd-logind 2>/dev/null || true
  if [[ -d /etc/gdm3 ]]; then
    deploy_file "$SOURCE/gdm3/custom.conf" /etc/gdm3/custom.conf
    echo "GDM Wayland enabled; log out (or reboot) for Sway to appear in the session menu"
  fi
fi

if has_deploy grub && [[ -f /etc/default/grub ]] && command -v update-grub >/dev/null 2>&1; then
  deploy_file "$SOURCE/grub/default" /etc/default/grub
  sudo update-grub 2>/dev/null || true
fi

if has_deploy ssh && [[ -d /etc/ssh ]]; then
  deploy_dir_file "$SOURCE/ssh/sshd_config.d/99-keyonly-port.conf" \
    /etc/ssh/sshd_config.d/99-keyonly-port.conf
  deploy_dir_file "$SOURCE/ssh/ssh.socket.d/port.conf" \
    /etc/systemd/system/ssh.socket.d/port.conf
  if command -v systemctl >/dev/null 2>&1; then
    sudo mkdir -p /etc/systemd/system/ssh.service.requires
    sudo ln -sf /usr/lib/systemd/system/ssh.socket \
      /etc/systemd/system/ssh.service.requires/ssh.socket 2>/dev/null || true
    sudo systemctl daemon-reload 2>/dev/null || true
    sudo systemctl enable ssh.socket 2>/dev/null || true
  fi
fi

if has_deploy llama && { command -v llama-swap >/dev/null 2>&1 || [[ -x /usr/local/bin/llama-swap ]]; }; then
  TMP_LLAMA_SWAP="$(mktemp)"
  chezmoi execute-template < "$SOURCE/systemd/llama-swap.service.tmpl" > "$TMP_LLAMA_SWAP"
  deploy_file "$TMP_LLAMA_SWAP" /etc/systemd/system/llama-swap.service
  rm -f "$TMP_LLAMA_SWAP"
  sudo systemctl daemon-reload 2>/dev/null || true
  # Retire Ollama if previously deployed.
  sudo systemctl disable --now ollama.service 2>/dev/null || true
  sudo rm -f /etc/systemd/system/ollama.service
  sudo rm -rf /etc/systemd/system/ollama.service.d
fi

if has_deploy keyd && {
  command -v keyd >/dev/null 2>&1 ||
  command -v keyd.rvaiya >/dev/null 2>&1 ||
  [[ -x /usr/bin/keyd.rvaiya ]]
}; then
  sudo install -d /etc/keyd
  deploy_file "$SOURCE/keyd/default.conf" /etc/keyd/default.conf
  sudo systemctl enable keyd 2>/dev/null || true
  sudo systemctl restart keyd 2>/dev/null || true
fi

if has_deploy libinput; then
  TMP_QUIRKS="$(mktemp)"
  chezmoi execute-template < "$SOURCE/libinput/local-overrides.quirks.tmpl" > "$TMP_QUIRKS"
  sudo install -d /etc/libinput
  deploy_file "$TMP_QUIRKS" /etc/libinput/local-overrides.quirks
  rm -f "$TMP_QUIRKS"
fi

echo "System configuration deployed"
{{ end -}}
