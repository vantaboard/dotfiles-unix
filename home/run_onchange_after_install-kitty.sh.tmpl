{{ if and (eq .chezmoi.os "linux") -}}
{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "kitty" -}}
#!/bin/bash
set -euo pipefail

# hash: kitty-v1

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping kitty install"
  exit 0
fi

HOME_DIR="{{ .chezmoi.homeDir }}"
KITTY_APP="$HOME_DIR/.local/kitty.app"
KITTY_BIN="$KITTY_APP/bin/kitty"
KITTEN_BIN="$KITTY_APP/bin/kitten"
LOCAL_BIN="$HOME_DIR/.local/bin"

link_kitty_bins() {
  mkdir -p "$LOCAL_BIN"
  ln -sf "$KITTY_BIN" "$KITTEN_BIN" "$LOCAL_BIN/"
}

if [[ -x "$KITTY_BIN" ]]; then
  echo "kitty already installed at $KITTY_BIN"
  link_kitty_bins
  exit 0
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "WARN: curl not found; skipping kitty install"
  exit 0
fi

echo "Installing kitty via official installer..."
curl -L https://sw.kovidgoyal.net/kitty/installer.sh | sh /dev/stdin

if [[ -x "$KITTY_BIN" ]]; then
  link_kitty_bins
  echo "kitty installed; linked kitty and kitten in $LOCAL_BIN"
else
  echo "WARN: kitty install failed ($KITTY_BIN missing)"
  exit 0
fi
{{- end -}}
{{ end -}}
