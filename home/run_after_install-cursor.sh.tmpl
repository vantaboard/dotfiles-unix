{{ if eq .chezmoi.os "linux" -}}
{{- $p := .profile_example -}}
{{- if index . "profile" -}}{{- $p = .profile -}}{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "cursor" -}}
#!/bin/bash
set -euo pipefail

# hash: cursor-dev-appimage-v1

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping Cursor AppImage install"
  exit 0
fi

HOME_DIR="{{ .chezmoi.homeDir }}"
LOCAL_BIN="$HOME_DIR/.local/bin"
INSTALL_DIR="$HOME_DIR/.local/opt/cursor-dev"
CACHE_DIR="$HOME_DIR/.cache/cursor-dev-install"
APPIMAGE="$INSTALL_DIR/Cursor.AppImage"
VERSION_FILE="$INSTALL_DIR/version"
UPDATE_CHANNEL="dev"
UPDATE_BASE_VERSION="${CURSOR_UPDATE_BASE_VERSION:-0.0.0}"
UPDATE_SEED_SHA="${CURSOR_UPDATE_SEED_SHA:-b596604857d12725c2c353227badabbfd503ace59109393916d369c399dfd1a6}"
UPDATE_URL="https://api2.cursor.sh/updates/api/update/linux-x64/cursor/${UPDATE_BASE_VERSION}/${UPDATE_SEED_SHA}/${UPDATE_CHANNEL}"

case "$(uname -m)" in
  x86_64) ;;
  *)
    echo "WARN: unsupported architecture $(uname -m); skipping Cursor AppImage install"
    exit 0
    ;;
esac

if ! command -v curl >/dev/null 2>&1; then
  echo "WARN: curl not found; skipping Cursor AppImage install"
  exit 0
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "WARN: jq not found; skipping Cursor AppImage install"
  exit 0
fi

metadata="$(curl -fsSL "$UPDATE_URL")"
target_version="$(jq -r '.productVersion // .version // empty' <<<"$metadata")"
update_asset_url="$(jq -r '.url // empty' <<<"$metadata")"

if [[ -z "$target_version" || -z "$update_asset_url" || "$update_asset_url" == "null" ]]; then
  echo "WARN: Cursor update API did not return a downloadable ${UPDATE_CHANNEL} AppImage"
  exit 0
fi

download_url="$update_asset_url"
if [[ "$download_url" == *.AppImage.zsync ]]; then
  download_url="${download_url%.zsync}"
fi

if [[ "$download_url" != *.AppImage ]]; then
  echo "WARN: Cursor update URL is not an AppImage: $download_url"
  exit 0
fi

link_cursor() {
  mkdir -p "$LOCAL_BIN"
  rm -f "$LOCAL_BIN/cursor"
  cat > "$LOCAL_BIN/cursor" <<EOF
#!/bin/bash
set -euo pipefail
exec "$APPIMAGE" --no-sandbox "\$@"
EOF
  chmod +x "$LOCAL_BIN/cursor"
}

appimage_current() {
  [[ -x "$APPIMAGE" ]] || return 1
  [[ -f "$VERSION_FILE" && "$(cat "$VERSION_FILE")" == "$target_version" ]] || return 1
  [[ "$(wc -c < "$APPIMAGE")" -gt 100000000 ]]
}

if appimage_current; then
  echo "Cursor ${UPDATE_CHANNEL} ${target_version} already installed at $APPIMAGE"
  link_cursor
  exit 0
fi

mkdir -p "$INSTALL_DIR" "$CACHE_DIR"
tmp_file="$(mktemp "${CACHE_DIR}/Cursor.AppImage.XXXXXX")"
cleanup() { rm -f "$tmp_file"; }
trap cleanup EXIT

echo "Installing Cursor ${UPDATE_CHANNEL} ${target_version} AppImage..."
curl -fsSL "$download_url" -o "$tmp_file"
chmod +x "$tmp_file"
mv "$tmp_file" "$APPIMAGE"
printf '%s\n' "$target_version" > "$VERSION_FILE"
link_cursor

echo "Cursor ${UPDATE_CHANNEL} ${target_version} installed; cursor -> $APPIMAGE"
{{- end -}}
{{ end -}}
