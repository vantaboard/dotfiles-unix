#!/bin/bash
set -euo pipefail

# GDM does not reliably pass multi-value environment.d variables (colons get
# truncated). Load Wayland session env here before exec'ing sway.
env_file="${XDG_CONFIG_HOME:-$HOME/.config}/environment.d/wayland.conf"
if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

unreal_env="${XDG_CONFIG_HOME:-$HOME/.config}/environment.d/unreal.conf"
if [[ -f "$unreal_env" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$unreal_env"
  set +a
fi

# Expose both GPUs so dock hotplug works live without restarting the session.
# The external displays are wired to the NVIDIA dGPU; the laptop panel to the
# Intel iGPU. NVIDIA is listed first (primary renderer): wlroots' Intel-render/
# NVIDIA-scanout path is unstable, whereas NVIDIA-render/Intel-scanout works.
#
# DRM card numbers are NOT stable across boots (nvidia-drm and i915 race at
# boot, so either can grab card1). Resolve nodes by driver name instead of
# hardcoding cardN.
find_card_by_driver() {
  local driver="$1" card node
  for card in /sys/class/drm/card[0-9]*; do
    [[ -e "$card/device/driver" ]] || continue
    [[ "$(basename "$(readlink -f "$card/device/driver")")" == "$driver" ]] || continue
    node="/dev/dri/$(basename "$card")"
    [[ -e "$node" ]] && { echo "$node"; return 0; }
  done
  return 1
}

# nvidia-drm often appears several seconds after GDM starts the session. Wait
# for the NVIDIA node at early boot rather than falling back to Intel-only too
# eagerly.
nvidia_card="$(find_card_by_driver nvidia || true)"
if [[ -z "$nvidia_card" && -d /sys/module/nvidia ]]; then
  read -r uptime _ </proc/uptime
  if awk "BEGIN { exit !($uptime < 120) }"; then
    for _ in $(seq 1 30); do
      nvidia_card="$(find_card_by_driver nvidia || true)"
      [[ -n "$nvidia_card" ]] && break
      sleep 1
    done
  fi
fi
intel_card="$(find_card_by_driver i915 || true)"

if [[ -n "$nvidia_card" ]]; then
  export WLR_DRM_DEVICES="${nvidia_card}${intel_card:+:${intel_card}}"
  # wlroots' GLES2 path on the proprietary NVIDIA driver corrupts buffers
  # session-wide (heavy apps like Cursor trigger it), and the pixman software
  # renderer fixes it but is too slow. The Vulkan renderer is GPU-accelerated
  # and avoids the broken GLES2/GBM path.
  export WLR_RENDERER=vulkan
elif [[ -n "$intel_card" ]]; then
  # NVIDIA unavailable (driver failure): laptop panel only, Intel GLES2.
  export WLR_DRM_DEVICES="$intel_card"
fi

SWAYFX_BIN="${HOME}/.local/bin/swayfx"

if [[ -x "$SWAYFX_BIN" ]]; then
  export LD_LIBRARY_PATH="${HOME}/.local/lib/x86_64-linux-gnu:${HOME}/.local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  exec "$SWAYFX_BIN" --unsupported-gpu "$@"
fi

exec sway --unsupported-gpu "$@"
