#!/bin/bash
set -euo pipefail

# GDM does not reliably pass multi-value environment.d variables (colons get
# truncated). Load Wayland session env here before exec'ing sway.
env_file="${XDG_CONFIG_HOME:-$HOME/.config}/environment.d/wayland.conf"
if [[ -f "$env_file" ]]; then
  set -a
  # shellcheck disable=SC1090
  source "$env_file"
  set +a
fi

# Avoid wlroots' Intel-render/NVIDIA-scanout path when docked. The external
# displays are wired to card2; the laptop panel is wired to card1.
docked=0
for status in /sys/class/drm/card2-DP-*/status; do
  [[ -e "$status" ]] || continue
  if [[ "$(cat "$status")" == "connected" ]]; then
    docked=1
    break
  fi
done

if [[ "$docked" == "1" && -e /dev/dri/card2 ]]; then
  export WLR_DRM_DEVICES=/dev/dri/card2
  # Docked scans out on NVIDIA. wlroots' GLES2 path on the proprietary driver
  # corrupts buffers session-wide (heavy apps like Cursor trigger it), and the
  # pixman software renderer fixes it but is too slow. The Vulkan renderer is
  # GPU-accelerated and avoids the broken GLES2/GBM path. Undocked stays on
  # Intel GLES2 (fast and stable).
  export WLR_RENDERER=vulkan
elif [[ -e /dev/dri/card1 ]]; then
  export WLR_DRM_DEVICES=/dev/dri/card1
fi

SWAYFX_BIN="${HOME}/.local/bin/swayfx"

if [[ -x "$SWAYFX_BIN" ]]; then
  export LD_LIBRARY_PATH="${HOME}/.local/lib/x86_64-linux-gnu:${HOME}/.local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
  exec "$SWAYFX_BIN" --unsupported-gpu "$@"
fi

exec sway --unsupported-gpu "$@"
