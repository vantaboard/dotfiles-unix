#!/bin/bash
# Re-apply sway display layout after the system wakes from sleep.
# systemd-sleep invokes: displays-resume <pre|post> <suspend|hibernate|...>
set -euo pipefail

USER_NAME="{{ .chezmoi.username }}"
HOME_DIR="{{ .chezmoi.homeDir }}"

case "${1}/${2}" in
  post/*)
    uid="$(id -u "$USER_NAME")"
    # Anything forked from this hook (even nohup'd) stays in the
    # systemd-suspend.service cgroup and is killed ~1s after wake when the
    # unit deactivates. Launch a transient unit instead so the recovery
    # script survives long enough to actually fix the outputs.
    # || true: a unit from a previous wake may still be running (name clash);
    # the script's flock dedupes anyway and the hook must not fail the cycle.
    systemd-run --collect --unit="displays-resume-wake" \
      --uid="$uid" \
      --setenv="XDG_RUNTIME_DIR=/run/user/${uid}" \
      --setenv="HOME=${HOME_DIR}" \
      "${HOME_DIR}/.local/bin/displays-resume" --foreground || true
    ;;
esac

exit 0
