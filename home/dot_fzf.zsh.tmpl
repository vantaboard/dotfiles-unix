{{- $p := .profile_example -}}
{{- if index . "profile" -}}{{- $p = .profile -}}{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if index $p.features "fzf" }}
# Setup fzf
# ---------
# Prepend so git-installed fzf wins over distro packages (e.g. Ubuntu's older
# /usr/bin/fzf). Newer key-bindings require flags the distro build lacks.
if [[ ! "$PATH" == *{{ .chezmoi.homeDir }}/.fzf/bin* ]]; then
  PATH="{{ .chezmoi.homeDir }}/.fzf/bin${PATH:+:$PATH}"
fi

# Auto-completion
# ---------------
[[ $- == *i* ]] && source "{{ .chezmoi.homeDir }}/.fzf/shell/completion.zsh" 2> /dev/null

# Key bindings
# ------------
[[ -f "{{ .chezmoi.homeDir }}/.fzf/shell/key-bindings.zsh" ]] \
  && source "{{ .chezmoi.homeDir }}/.fzf/shell/key-bindings.zsh"
{{- end }}
