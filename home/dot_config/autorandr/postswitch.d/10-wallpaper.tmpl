#!/usr/bin/bash

# Remove the nvidia-settings block entirely. It fights with autorandr.
# Just keep the nitrogen part.

sleep 1 # Reduced sleep

declare -a wallpapers=(
    "pexels-pachon-in-motion-426015731-18337644.jpg"
    "pexels-pachon-in-motion-426015731-18545010.jpg"
    "pexels-vahapdmr-18515329.jpg"
)

# Use your specific user's nitrogen config
export XAUTHORITY="/run/user/{{ .chezmoi.uid }}/gdm/Xauthority"

# Get current connected count accurately
count=$(xrandr | grep -c " connected")

for (( i=0; i<$count; i++))
do
    wall="${wallpapers[$i]}"
    # Fallback to the first wallpaper if we have more monitors than wallpapers
    [ -z "$wall" ] && wall="${wallpapers[0]}"
    
    nitrogen --head=$i --set-zoom-fill "$HOME/.wallpapers/$wall"
done
