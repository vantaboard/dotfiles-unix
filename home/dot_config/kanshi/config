# Docked: three externals on NVIDIA (card2). The sway-session wrapper uses
# card2 only when docked, so the Intel laptop panel is not exposed to Sway.
# Order matters — more specific docked profile must come before undocked.
profile docked-home {
    output DP-4 enable mode 1920x1080@60Hz position 0,0
    output DP-5 enable mode 1920x1080@60Hz position 1920,0
    output DP-6 enable mode 1920x1080@119.98Hz position 3840,0
    exec $HOME/.config/kanshi/postswitch.d/10-sway
}

profile undocked {
    output eDP-1 enable mode 1920x1080@144Hz position 0,0
    exec $HOME/.config/kanshi/postswitch.d/10-sway
}
