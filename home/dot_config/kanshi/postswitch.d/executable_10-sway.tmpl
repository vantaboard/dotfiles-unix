#!/usr/bin/bash

external_active=0
if [ -n "${SWAYSOCK:-}" ]; then
    external_active="$(swaymsg -t get_outputs | jq '[.[] | select(.name | test("^DP-")) | select(.active)] | length')"
fi

if [[ "$external_active" -ge 3 ]]; then
    MONITOR_ARRAY=(DP-4 DP-5 DP-6)
    LAYOUT_OUTPUT=$'output DP-4 position 0 0\noutput DP-5 position 1920 0\noutput DP-6 position 3840 0\noutput eDP-1 disable\n'
else
    ACTIVE_MONITORS=$(
        swaymsg -t get_outputs | jq -r '
            .[] | select(.active) | .rect.x as $x | "\($x) \(.name)"' | sort -n | awk '{print $2}'
    )
    MONITOR_ARRAY=($ACTIVE_MONITORS)
    LAYOUT_OUTPUT=$'output eDP-1 enable mode 1920x1080@144Hz position 0,0\n'
fi

MOVE_KEYS=("b" "n" "m")

CONFIG_OUTPUT="############# Auto-generated for use with kanshi #############\n"
CONFIG_OUTPUT+="${LAYOUT_OUTPUT}\n"

for i in $(seq 0 $((${#MONITOR_ARRAY[@]}-1))); do
    SCREEN_NAME="screen$i"
    monitor=${MONITOR_ARRAY[$i]}

    CONFIG_OUTPUT+="set \$$SCREEN_NAME $monitor\n"
    CONFIG_OUTPUT+="workspace \$ws$i output \$$SCREEN_NAME\n"

    if [ $i -lt ${#MOVE_KEYS[@]} ]; then
        CONFIG_OUTPUT+="bindsym \$mod+shift+${MOVE_KEYS[$i]} move workspace to output \$$SCREEN_NAME\n"
    fi
done

WORKSPACE_NAMES=("web" "code" "media" "comms" "misc" "av" "other" "other")

for i in {0..7}; do
    INDEX_FROM_ONE=$((i + 1))
    WS="\$ws$i"

    CONFIG_OUTPUT+="bindsym \$mod+$INDEX_FROM_ONE workspace $WS\n"
    CONFIG_OUTPUT+="bindsym \$mod+Ctrl+$INDEX_FROM_ONE move container to workspace $WS\n"
    CONFIG_OUTPUT+="bindsym \$mod+Shift+$INDEX_FROM_ONE move container to workspace $WS; workspace $WS\n"
    CONFIG_OUTPUT+="set $WS $INDEX_FROM_ONE:${WORKSPACE_NAMES[$i]}\n"
done

CONFIG_FILE="$HOME/.config/sway/config"
NEW_BLOCK=$(printf '%b' "$CONFIG_OUTPUT")
OLD_BLOCK=$(sed -n '/^############# Auto-generated for use with kanshi #############/,$p' "$CONFIG_FILE" 2>/dev/null || true)

if [[ -n "$OLD_BLOCK" && "$NEW_BLOCK" == "$OLD_BLOCK" ]]; then
    if [ -n "${SWAYSOCK:-}" ]; then
        "$HOME/.local/bin/sway-docked-layout"
    fi
    echo "sway monitor layout unchanged; skipping reload."
    exit 0
fi

sed -i '/############# Auto-generated for use with kanshi #############/,$d' "$CONFIG_FILE"
printf '%b' "$CONFIG_OUTPUT" >> "$CONFIG_FILE"

if [ -n "${SWAYSOCK:-}" ]; then
    swaymsg reload
    "$HOME/.local/bin/sway-docked-layout"
    "$HOME/.local/bin/sway-wallpaper"
fi

echo "sway config reloaded."
