include /etc/sway/config.d/*

{{- $p := .profile_example -}}
{{- if index . "profile" -}}{{- $p = .profile -}}{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- $f := $p.features -}}
{{- $swayfxEnabled := false -}}
{{- if eq (index $f "swayfx") true -}}
{{-   $swayfxEnabled = true -}}
{{- else if and (index $f "desktop_sway") (ne (index $f "swayfx") false) -}}
{{-   $swayfxEnabled = true -}}
{{- end -}}

# Wayland session startup
# Propagate the dynamic Wayland session env into the systemd user manager and
# D-Bus activation environment. Without WAYLAND_DISPLAY here, dbus/systemd
# activated services (notably xdg-desktop-portal and its gtk backend) start
# without a display, fail to activate, and any portal call blocks for the full
# ~25s D-Bus timeout — which makes Waybar exit and leaves no status bar.
exec --no-startup-id dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP XDG_SESSION_TYPE SWAYSOCK
exec --no-startup-id dunst
exec --no-startup-id sunshine
exec --no-startup-id kanshi
exec_always --no-startup-id $HOME/.local/bin/sway-wallpaper

include $HOME/.config/sway/input-devices.conf

input type:keyboard xkb_layout "us,es"
input type:keyboard xkb_options "grp:alt_shift_toggle"
{{- if $swayfxEnabled }}
# Hide the cursor after idle ms but keep pointer/hover active.
# Vanilla sway clears focus on hide; swayfx is patched in install-tools.
seat * hide_cursor 500
{{- end }}
seat * xcursor_theme Adwaita 24

exec swayidle -w \
    timeout 600 'swaymsg "output * dpms off"' \
    timeout 1200 'swaylock -f -c $HOME/.config/swaylock/config' \
    timeout 1800 'systemctl suspend' \
    before-sleep 'swaylock -f -c $HOME/.config/swaylock/config'
exec --no-startup-id systemctl --user enable --now displays-resume.service

# Start a hidden kitty instance for fast startup
exec --no-startup-id $HOME/.local/bin/kitty --single-instance --class "scratchpad-kitty" --listen-on unix:/tmp/kitty-socket --start-as hidden

set $mod Mod4

default_border pixel 4
default_floating_border normal

hide_edge_borders none

focus_follows_mouse no

exec --no-startup-id su - {{ .chezmoi.username }} -c "tmux new -s musikcube -d musikcube"

exec --no-startup-id unclutte0
exec --no-startup-id webcam
exec_always --no-startup-id copyq

bindsym $mod+u border none
bindsym $mod+y border pixel 3
bindsym $mod+n border normal
bindsym $mod+Return exec $HOME/.local/bin/kitty --single-instance --class "scratchpad-kitty" --listen-on unix:/tmp/kitty-socket
bindsym $mod+Shift+q kill
bindsym $mod+shift+w exec /usr/bin/python $HOME/.local/bin/cameractrls2 -d "/dev/video2" -s exposure_time_absolute,50,800
bindsym $mod+d exec --no-startup-id $HOME/.local/bin/bemenu-drun
bindsym $mod+z exec --no-startup-id rofi -show run

font pango:FixedsysExcelsior Nerd Font Mono 10

floating_modifier $mod

exec --no-startup-id volumeicon
exec --no-startup-id pulseaudio
exec --no-startup-id pa-applet
bindsym $mod+Ctrl+m exec pavucontrol

bindsym $mod+Ctrl+b exec terminal -e 'bmenu'
bindsym $mod+F3 exec pcmanfm
bindsym $mod+Shift+F3 exec pcmanfm_pkexec
bindsym $mod+F5 exec terminal -e 'mocp'
bindsym $mod+Ctrl+Shift+s exec --no-startup-id $HOME/.local/bin/suspend
bindsym $mod+Ctrl+Shift+h exec --no-startup-id systemctl hibernate
bindsym $mod+Shift+s exec --no-startup-id $HOME/.local/bin/screenshot-region
bindsym $mod+Shift+a exec --no-startup-id normcap
bindsym $mod+Ctrl+Shift+n input type:keyboard xkb_next_layout
bindsym Print exec --no-startup-id sh -c 'grim -g "$(slurp)" - | wl-copy'
bindsym $mod+Ctrl+x exec --no-startup-id swaymsg kill
bindsym $mod+Shift+e exec --no-startup-id $HOME/.local/bin/rofi-emoji

bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+x split h;exec notify-send 'tile horizontally'
bindsym $mod+c split v;exec notify-send 'tile vertically'
bindsym $mod+q split toggle

bindsym $mod+f fullscreen toggle

bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split

bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle
bindsym $mod+Shift+f sticky toggle
bindsym $mod+a focus parent
bindsym $mod+Shift+minus move scratchpad
bindsym $mod+minus scratchpad show
bindsym $mod+Ctrl+Right workspace next
bindsym $mod+Ctrl+Left workspace prev

bindsym $mod+Ctrl+Shift+k exec --no-startup-id swaylock -f -c $HOME/.config/swaylock/config

for_window [class="Vncviewer"] fullscreen enable global
for_window [class="Cursor"] border none
for_window [class="kooha"] floating enable border pixel 1
for_window [title="alsamixer"] floating enable border pixel 1
for_window [class="calamares"] floating enable border normal
for_window [class="Clipgrab"] floating enable
for_window [title="File Transfer*"] floating enable
for_window [class="fpakman"] floating enable
for_window [class="Galculator"] floating enable border pixel 1
for_window [class="GParted"] floating enable border normal
for_window [class="Lightdm-settings"] floating enable
for_window [class="Manjaro-hello"] floating enable
for_window [class="Manjaro Settings Manager"] floating enable border normal
for_window [title="MuseScore: Play Panel"] floating enable
for_window [class="Oblogout"] fullscreen enable
for_window [class="octopi"] floating enable
for_window [title="About Pale Moon"] floating enable
for_window [class="Pamac-manager"] floating enable
for_window [class="Pavucontrol"] floating enable
for_window [class="qt5ct"] floating enable sticky enable border normal
for_window [class="Qtconfig-qt4"] floating enable sticky enable border normal
for_window [class="Simple-scan"] floating enable border normal
for_window [class="Timeset-gui"] floating enable border normal
for_window [class="(?i)virtualbox"] floating enable border normal
for_window [class="Xfburn"] floating enable

for_window [urgent=latest] focus

bindsym $mod+Shift+r reload

bindsym $mod+0 mode "$mode_system"
set $mode_system (l)ock, (e)xit, switch_(u)ser, (s)uspend, (h)ibernate, (r)eboot, (Shift+s)hutdown
mode "$mode_system" {
    bindsym l exec --no-startup-id swaylock -f -c $HOME/.config/swaylock/config, mode "default"
    bindsym s exec --no-startup-id $HOME/.local/bin/suspend, mode "default"
    bindsym u exec --no-startup-id loginctl terminate-user $USER, mode "default"
    bindsym e exec --no-startup-id swaymsg exit, mode "default"
    bindsym h exec --no-startup-id systemctl hibernate, mode "default"
    bindsym r exec --no-startup-id systemctl reboot, mode "default"
    bindsym Shift+s exec --no-startup-id systemctl poweroff, mode "default"

    bindsym Return mode "default"
    bindsym Escape mode "default"
}

bindsym $mod+r mode "resize"
mode "resize" {
        bindsym h resize shrink width 5 px or 5 ppt
        bindsym j resize grow height 5 px or 5 ppt
        bindsym k resize shrink height 5 px or 5 ppt
        bindsym l resize grow width 5 px or 5 ppt

        bindsym Return mode "default"
        bindsym Escape mode "default"
}

exec --no-startup-id /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1
exec --no-startup-id nm-applet --indicator
exec --no-startup-id xfce4-power-manager
exec --no-startup-id pamac-tray

exec --no-startup-id systemctl --user disable --now waybar.service
exec_always --no-startup-id $HOME/.local/bin/waybar-restart

bindsym $mod+m exec pkill -SIGUSR2 waybar

# class                 border   bground  text     indicator child_border
client.focused          #86a83e  #84c137  #0f0a05  #23ff18   #86a83e
client.focused_inactive #083905  #0c0804  #84c137  #00a600   #083905
client.unfocused        #0c0804  #0f0a05  #666666  #083905
client.urgent           #b6204a  #e50000  #e5e5e5  #e50000   #e50000
client.placeholder      #000000  #0c0804  #666666  #000000   #0c0804

client.background       #0f0a05

{{- if $swayfxEnabled }}
# Compositor effects (SwayFX)
# Deep green tint lifts windows off the wallpaper
shadows enable
shadows_on_csd enable
shadow_blur_radius 18
shadow_color #0839058C
shadow_offset -6 -6

# Blur wallpaper behind semi-transparent windows (kitty sets its own opacity)
blur enable
blur_xray disable
blur_passes 3
blur_radius 6
{{- end }}

# Default opaque — only clients that set their own opacity (e.g. kitty) go translucent
for_window [class="waybar"] opacity 1.0
for_window [app_id="waybar"] opacity 1.0
for_window [class="Polybar"] opacity 1.0
for_window [class="Dunst"] opacity 1.0
for_window [app_id="Dunst"] opacity 1.0
for_window [class="(?i)notification"] opacity 1.0
for_window [class="Rofi"] opacity 1.0
for_window [app_id="Rofi"] opacity 1.0
for_window [app_id="rofi"] opacity 1.0
for_window [class="dmenu"] opacity 1.0
for_window [class="copyq"] opacity 1.0
for_window [class="Pavucontrol"] opacity 1.0
for_window [class="Galculator"] opacity 1.0
for_window [class="swappy"] opacity 1.0
for_window [class="normcap"] opacity 1.0
for_window [class="kooha"] opacity 1.0
for_window [class="Oblogout"] opacity 1.0
for_window [class="Xfce4-notifyd"] opacity 1.0
for_window [class="xfce4-notifyd"] opacity 1.0
for_window [class="vlc"] opacity 1.0
for_window [class="mpv"] opacity 1.0
for_window [class="Steam"] opacity 1.0
for_window [class="steam_app"] opacity 1.0
for_window [class="steamwebhelper"] opacity 1.0
for_window [class="Wine"] opacity 1.0
for_window [class="(?i)gamescope"] opacity 1.0
for_window [class="VirtualBox"] opacity 1.0
for_window [class="VirtualBox Machine"] opacity 1.0
for_window [class="obs"] opacity 1.0
for_window [class="zoom"] opacity 1.0
for_window [class="firefox"] opacity 1.0
for_window [app_id="firefox"] opacity 1.0
for_window [class="Google-chrome"] opacity 1.0
for_window [class="chromium"] opacity 1.0
for_window [class="Chromium"] opacity 1.0
for_window [app_id="chromium"] opacity 1.0

gaps inner 5
gaps outer 10
gaps top 20

set $mode_gaps Gaps: (o) outer, (i) inner
set $mode_gaps_outer Outer Gaps: +|-|0 (local), Shift + +|-|0 (global)
set $mode_gaps_inner Inner Gaps: +|-|0 (local), Shift + +|-|0 (global)
bindsym $mod+Shift+g mode "$mode_gaps"

mode "$mode_gaps" {
        bindsym o      mode "$mode_gaps_outer"
        bindsym i      mode "$mode_gaps_inner"
        bindsym Return mode "default"
        bindsym Escape mode "default"
}
mode "$mode_gaps_inner" {
        bindsym plus  gaps inner current plus 5
        bindsym minus gaps inner current minus 5
        bindsym 0     gaps inner current set 0

        bindsym Shift+plus  gaps inner all plus 5
        bindsym Shift+minus gaps inner all minus 5
        bindsym Shift+0     gaps inner all set 0

        bindsym Return mode "default"
        bindsym Escape mode "default"
}
mode "$mode_gaps_outer" {
        bindsym plus  gaps outer current plus 5
        bindsym minus gaps outer current minus 5
        bindsym 0     gaps outer current set 0

        bindsym Shift+plus  gaps outer all plus 5
        bindsym Shift+minus gaps outer all minus 5
        bindsym Shift+0     gaps outer all set 0

        bindsym Return mode "default"
        bindsym Escape mode "default"
}

