{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "unreal" -}}
{{- $engine := $p.unreal_engine_path | default "" -}}
local engine_path = {{ $engine | quote }}

vim.g.unreal_engine_path = engine_path

-- Sway/Wayland + NVIDIA: route the window through XWayland. Linux desktop RHI
-- is Vulkan-only (OpenGL was removed in UE 4.26); -opengl is ignored with a warning.
local launch_env = {
  SDL_VIDEODRIVER = "x11",
}

require("unrealengine").setup({
  engine_path = engine_path,
  build_type = "Development",
  with_editor = true,
  auto_generate = true,
  environment_variables = launch_env,
})

local commands = require("unrealengine.commands")
local helpers = require("unrealengine.helpers")

local function open_editor()
  local binary = vim.fs.joinpath(engine_path, "Engine/Binaries/Linux/UnrealEditor")
  local cmd = { binary }
  local uproject = helpers.get_uproject_path_info(nil)
  if uproject then
    table.insert(cmd, uproject.path)
  end

  local env = vim.fn.environ()
  for k, v in pairs(launch_env) do
    env[k] = v
  end
  if vim.v.servername and vim.v.servername ~= "" then
    env.NVIM = vim.v.servername
  end

  vim.fn.jobstart(cmd, { detach = true, env = env })
end

local function install_engine_plugin()
  local script = vim.fn.expand("~/.local/bin/install-unreal-neovim-plugin")
  if vim.fn.executable(script) ~= 1 then
    vim.notify("install-unreal-neovim-plugin not found; run chezmoi apply", vim.log.levels.ERROR)
    return
  end
  vim.cmd("botright split")
  vim.fn.termopen({ script, engine_path }, { cwd = engine_path })
end

vim.keymap.set("n", "<leader>ug", commands.generate_lsp, { desc = "UnrealEngine: Generate LSP" })
vim.keymap.set("n", "<leader>ub", commands.build, { desc = "UnrealEngine: Build" })
vim.keymap.set("n", "<leader>ur", commands.rebuild, { desc = "UnrealEngine: Rebuild" })
vim.keymap.set("n", "<leader>uc", commands.clean, { desc = "UnrealEngine: Clean" })
vim.keymap.set("n", "<leader>uo", open_editor, { desc = "UnrealEngine: Open Editor" })
-- build_plugin symlinks outside the engine tree; UE 5.8 skips the plugin on scan.
vim.keymap.set("n", "<leader>ue", install_engine_plugin, { desc = "UnrealEngine: Build Engine Plugin" })
{{- end -}}
