{
    "layer": "top",
    "position": "bottom",
    "height": 22,
    "spacing": 4,
    "modules-left": [
        "sway/workspaces"
    ],
    "modules-right": [
        "custom/py3status",
        "tray"
    ],
    "sway/workspaces": {
        "disable-scroll": true,
        "warp-on-scroll": false
    },
    "custom/py3status": {
        "interval": 5,
        "format": "{}",
        "exec": "{{ .chezmoi.homeDir }}/.local/bin/waybar-py3status-snapshot"
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    }
}
