bar {
	i3bar_command i3bar
	status_command py3status
    tray_output primary
	position bottom
	bindsym button4 nop
	bindsym button5 nop

    colors {
        background #0f0a05
        statusline #84c137
        separator  #083905

#                          border   backgr.   text
        focused_workspace  #84c137  #083905   #eeeeee
        active_workspace   #666666  #0c0804   #86a83e
        inactive_workspace #666666  #0f0a05   #666666
        binding_mode       #23ff18  #083905   #eeeeee
        urgent_workspace   #e50000  #b6204a   #e5e5e5
    }
}

