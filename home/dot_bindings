# Clipboard bindings (clip_copy, clip_paste, notify_user from ~/.export).

function copy-path {
    cwd=$(pwd | tr -d '\n')

    # if there are spaces in the path, wrap it in quotes
    if [[ $cwd == *" "* ]]; then
        cwd="\"$cwd\""
    fi

    echo $cwd | clip_copy
    notify_user "$cwd copied to clipboard"
}

function paste-clipboard-r {
    RBUFFER="${BUFFER}  $(clip_paste)"
}

function paste-clipboard {
    LBUFFER="${BUFFER}$(clip_paste)"
}

function copy-clipboard {
    if [ -z $BUFFER ]; then
        return
    fi

    echo $BUFFER | clip_copy
    notify_user "$BUFFER copied to clipboard"
}

function fzf-dir {
    cd "$(fzf_dirs)" || return
    zle reset-prompt
    zle redisplay
}

zle -N paste-clipboard
bindkey -r ^s
bindkey ^s paste-clipboard

zle -N paste-clipboard-r
bindkey ^w paste-clipboard-r

zle -N copy-path
bindkey ^a copy-path

zle -N fzf-dir
bindkey ^u fzf-dir

bindkey ^j autosuggest-accept
bindkey '^[OA' up-line-or-history
bindkey '^[OB' down-line-or-history
