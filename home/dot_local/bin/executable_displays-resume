#!/usr/bin/bash
# Re-apply the sway display layout after resume from suspend/hibernate.
#
# NVIDIA MST dock outputs often need many seconds after wake before modes are
# valid. A physical dock replug triggers DRM hotplug, kanshi re-matches the
# docked-home profile, and postswitch runs — HUP alone does not. After DRM is
# ready we simulate that: stop kanshi, cycle dock outputs, restart kanshi.
#
# Invoked from /usr/lib/systemd/system-sleep/displays-resume on post wake via
# a systemd-run transient unit (--foreground). A plain background fork from
# the sleep hook would die when systemd-suspend.service's cgroup is cleaned
# up ~1s after wake. Without --foreground (manual runs) we self-background.
set -uo pipefail

: "${HOME:=$(getent passwd "$(id -un)" | cut -d: -f6)}"
export HOME
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
LOG_DIR="${HOME}/.local/state"
LOG="${LOG_DIR}/displays-resume.log"
mkdir -p "$LOG_DIR"

if [[ "${1:-}" != "--foreground" ]]; then
    nohup "$0" --foreground >>"$LOG" 2>&1 &
    disown
    exit 0
fi

exec >>"$LOG" 2>&1
log() { echo "$(date -Is) $*"; }

log "=== displays-resume pid=$$ ==="

lockfile="${XDG_RUNTIME_DIR}/displays-resume.lock"
exec 9>"$lockfile"
flock -n 9 || { log "already running"; exit 0; }

find_swaysock() {
    find "$XDG_RUNTIME_DIR" -maxdepth 1 -name 'sway-ipc.*.sock' -type s 2>/dev/null | head -n1
}

if [[ -z "${SWAYSOCK:-}" || ! -S "${SWAYSOCK:-}" ]]; then
    SWAYSOCK="$(find_swaysock)"
    export SWAYSOCK
fi

swaymsg_cmd() {
    timeout 8 swaymsg "$@" 2>/dev/null
}

# Card numbers are not stable across boots (nvidia-drm/i915 probe race), so
# glob every card's connectors rather than assuming the dock GPU is card2.
docked_drm_ports_connected() {
    local count=0 port
    for port in /sys/class/drm/card*-DP-*/status; do
        [[ -e "$port" ]] || continue
        [[ "$(cat "$port" 2>/dev/null)" == "connected" ]] && ((count++)) || true
    done
    echo "$count"
}

dock_usb_present() {
    # VIA/Realtek hub tree on 3-5 is the dock; USB often reconnects tens of
    # seconds before NVIDIA MST exposes DP-4/5/6 after s2idle.
    [[ -e /sys/bus/usb/devices/3-5 ]] || return 1
    lsusb 2>/dev/null | grep -qE '2109:2822|2109:0822|0bda:5411'
}

is_docked() {
    [[ "$(docked_drm_ports_connected)" -ge 1 ]]
}

nvidia_modeset_errors_recent() {
    journalctl -k --since "5 sec ago" --no-pager 2>/dev/null \
        | awk '/nvidia-modeset: ERROR/ { count++ } END { print count + 0 }' \
        | head -n1
}

gbm_errors_recent() {
    journalctl -b --since "10 sec ago" --no-pager 2>/dev/null \
        | awk '/gbm_bo_create failed/ { count++ } END { print count + 0 }'
}

wait_for_swaysock() {
    local attempt
    for attempt in $(seq 1 90); do
        [[ -S "${SWAYSOCK:-}" ]] && { log "sway socket ready"; return 0; }
        SWAYSOCK="$(find_swaysock)"
        export SWAYSOCK
        (( attempt % 15 == 0 )) && log "waiting for sway socket (${attempt}s)"
        sleep 1
    done
    return 1
}

wait_for_drm() {
    local attempt count
    # Prefer waiting for dock DP when the USB hub is back but MST is still down.
    if dock_usb_present && ! is_docked; then
        for attempt in $(seq 1 120); do
            count="$(docked_drm_ports_connected)"
            [[ "$count" -ge 3 ]] && { log "DRM ready: ${count} DP ports connected"; return 0; }
            (( attempt % 15 == 0 )) && log "dock USB up, waiting for DP (${count}/3, ${attempt}s)"
            sleep 1
        done
        log "dock USB present but DP never enumerated; falling back"
    fi
    for attempt in $(seq 1 120); do
        if is_docked; then
            count="$(docked_drm_ports_connected)"
            [[ "$count" -ge 3 ]] && { log "DRM ready: ${count} DP ports connected"; return 0; }
            (( attempt % 15 == 0 )) && log "waiting for DRM (${count}/3 DP connected, ${attempt}s)"
        else
            local edp
            for edp in /sys/class/drm/card*-eDP-*/status; do
                [[ -e "$edp" ]] || continue
                [[ "$(cat "$edp" 2>/dev/null)" == "connected" ]] \
                    && { log "DRM ready: laptop panel connected"; return 0; }
            done
            (( attempt % 15 == 0 )) && log "waiting for laptop panel DRM (${attempt}s)"
        fi
        sleep 1
    done
    return 1
}

wait_for_gpu_ready() {
    local attempt quiet=0 errors
    for attempt in $(seq 1 90); do
        if is_docked; then
            errors="$(nvidia_modeset_errors_recent)"
            if [[ "$errors" -eq 0 ]]; then
                ((quiet++)) || true
                [[ "$quiet" -ge 5 ]] && { log "nvidia GPU quiet for ${quiet}s"; return 0; }
            else
                quiet=0
            fi
            (( attempt % 10 == 0 )) && log "waiting for nvidia GPU (${attempt}s, ${errors} errors/5s)"
        else
            return 0
        fi
        sleep 1
    done
    log "nvidia GPU wait timed out; proceeding"
    return 1
}

sway_dp_active_count() {
    swaymsg_cmd -t get_outputs \
        | jq -r '[.[] | select(.name | test("^DP-")) | select(.active)
                  | select(.current_mode.width // 0 > 0) | select(.dpms == true)] | length' \
        2>/dev/null || echo 0
}

sway_outputs_healthy() {
    local required="${1:-1}"
    local ready drm_count gbm_errors
    gbm_errors="$(gbm_errors_recent)"
    if is_docked; then
        ready="$(sway_dp_active_count)"
        drm_count="$(docked_drm_ports_connected)"
        [[ "$ready" -ge "$required" && "$drm_count" -ge 3 && "$gbm_errors" -eq 0 ]]
    else
        ready="$(swaymsg_cmd -t get_outputs \
            | jq -r '[.[] | select(.name == "eDP-1") | select(.active)
                      | select(.current_mode.width // 0 > 0) | select(.dpms == true)] | length' \
            2>/dev/null || echo 0)"
        # Dock USB is back but we only have the laptop panel: resume recovery
        # likely ran before MST came up and must not declare success.
        if dock_usb_present && [[ "$(docked_drm_ports_connected)" -ge 1 ]]; then
            return 1
        fi
        if dock_usb_present && [[ "$(sway_dp_active_count)" -eq 0 ]]; then
            return 1
        fi
        [[ "$ready" -ge 1 && "$gbm_errors" -eq 0 ]]
    fi
}

wait_for_kanshi_outputs() {
    local required="${1:-3}" attempt count
    for attempt in $(seq 1 45); do
        if sway_outputs_healthy "$required"; then
            log "kanshi restored ${required} outputs (${attempt}s)"
            return 0
        fi
        if (( attempt % 10 == 0 )); then
            count="$(sway_dp_active_count)"
            log "waiting for kanshi outputs (${count}/${required}, ${attempt}s, gbm_errors=$(gbm_errors_recent))"
        fi
        sleep 1
    done
    return 1
}

# Direct spawn: `swaymsg exec --no-startup-id kanshi` with separate args
# fails because swaymsg parses --no-startup-id as its own option (the error
# was swallowed by 2>/dev/null, so kanshi silently never restarted).
start_kanshi() {
    setsid -f env SWAYSOCK="${SWAYSOCK:-}" WAYLAND_DISPLAY="${WAYLAND_DISPLAY:-wayland-1}" \
        kanshi >/dev/null 2>&1 || true
}

simulate_dock_replug() {
    local out
    log "simulating dock replug (stop kanshi, cycle DP outputs, restart kanshi)"
    pkill -x kanshi 2>/dev/null || true
    sleep 1
    for out in DP-4 DP-5 DP-6; do
        swaymsg_cmd "output $out disable" || true
    done
    sleep 5
    start_kanshi
    wait_for_kanshi_outputs 3 || log "kanshi outputs slow after replug simulation"
}

apply_recovery() {
    local docked=no
    is_docked && docked=yes
    log "apply_recovery (docked=${docked})"
    swaymsg_cmd "output * dpms on" || true

    if is_docked; then
        simulate_dock_replug
    else
        pkill -x kanshi 2>/dev/null || true
        sleep 1
        start_kanshi
        wait_for_kanshi_outputs 1 || true
    fi

    if [[ -x "$HOME/.config/kanshi/postswitch.d/10-sway" ]]; then
        SWAYSOCK="${SWAYSOCK:-}" "$HOME/.config/kanshi/postswitch.d/10-sway" 2>/dev/null || true
    fi
    "$HOME/.local/bin/sway-docked-layout" 2>/dev/null || true
    "$HOME/.local/bin/sway-wallpaper" 2>/dev/null || true
    "$HOME/.local/bin/waybar-restart" 2>/dev/null || true
}

wait_for_swaysock || { log "no sway socket; user may be at login screen"; exit 0; }

wait_for_drm || log "drm wait timed out; proceeding anyway"
wait_for_gpu_ready || true
log "post-GPU settle pause"
sleep 5

required=1
if is_docked || dock_usb_present; then required=3; fi

for round in $(seq 1 5); do
    log "recovery round ${round} (need ${required} healthy outputs)"
    apply_recovery
    sleep 5
    count="$(sway_dp_active_count)"
    gbm="$(gbm_errors_recent)"
    log "round ${round} result: ${count}/${required} outputs, gbm_errors=${gbm}"
    if sway_outputs_healthy "$required"; then
        log "outputs healthy after round ${round}"
        "$HOME/.local/bin/input-recover" --foreground 2>/dev/null || true
        exit 0
    fi
    log "outputs still unhealthy after round ${round}; retrying"
    sleep 10
done

log "outputs still unhealthy; restarting sway so GDM can start a fresh session"
swaymsg_cmd exit || true
exit 0
