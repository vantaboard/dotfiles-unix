#!/usr/bin/bash
# Re-apply the sway display layout after resume from suspend/hibernate.
#
# NVIDIA MST dock outputs often need many seconds after wake before modes are
# valid. A physical dock replug triggers DRM hotplug, kanshi re-matches the
# docked-home profile, and postswitch runs — HUP alone does not. After DRM is
# ready we simulate that: stop kanshi, cycle dock outputs, restart kanshi.
#
# Invoked from /usr/lib/systemd/system-sleep/displays-resume on post wake.
# Re-exec in the background so the sleep hook returns immediately while we
# wait for DRM to settle.
set -euo pipefail

: "${HOME:=$(getent passwd "$(id -un)" | cut -d: -f6)}"
export HOME
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export XDG_SESSION_TYPE="${XDG_SESSION_TYPE:-wayland}"
LOG_DIR="${HOME}/.local/state"
LOG="${LOG_DIR}/displays-resume.log"
mkdir -p "$LOG_DIR"

if [[ "${1:-}" != "--foreground" ]]; then
    nohup "$0" --foreground >>"$LOG" 2>&1 &
    disown
    exit 0
fi

exec >>"$LOG" 2>&1
log() { echo "$(date -Is) $*"; }

log "=== displays-resume pid=$$ ==="

lockfile="${XDG_RUNTIME_DIR}/displays-resume.lock"
exec 9>"$lockfile"
flock -n 9 || { log "already running"; exit 0; }

find_swaysock() {
    find "$XDG_RUNTIME_DIR" -maxdepth 1 -name 'sway-ipc.*.sock' -type s 2>/dev/null | head -n1
}

if [[ -z "${SWAYSOCK:-}" || ! -S "${SWAYSOCK:-}" ]]; then
    SWAYSOCK="$(find_swaysock)"
    export SWAYSOCK
fi

wait_for_swaysock() {
    local attempt
    for attempt in $(seq 1 90); do
        [[ -S "${SWAYSOCK:-}" ]] && { log "sway socket ready"; return 0; }
        SWAYSOCK="$(find_swaysock)"
        export SWAYSOCK
        (( attempt % 15 == 0 )) && log "waiting for sway socket (${attempt}s)"
        sleep 1
    done
    return 1
}

docked_drm_ports_connected() {
    local count=0 port
    for port in /sys/class/drm/card2-DP-*/status; do
        [[ -e "$port" ]] || continue
        [[ "$(cat "$port" 2>/dev/null)" == "connected" ]] && ((count++)) || true
    done
    echo "$count"
}

is_docked() {
    [[ "$(docked_drm_ports_connected)" -ge 1 ]]
}

wait_for_drm() {
    local attempt count
    for attempt in $(seq 1 120); do
        if is_docked; then
            count="$(docked_drm_ports_connected)"
            [[ "$count" -ge 3 ]] && { log "DRM ready: ${count} DP ports connected"; return 0; }
            (( attempt % 15 == 0 )) && log "waiting for DRM (${count}/3 DP connected, ${attempt}s)"
        else
            [[ -e /sys/class/drm/card1-eDP-1/status ]] \
                && [[ "$(cat /sys/class/drm/card1-eDP-1/status 2>/dev/null)" == "connected" ]] \
                && { log "DRM ready: laptop panel connected"; return 0; }
            (( attempt % 15 == 0 )) && log "waiting for laptop panel DRM (${attempt}s)"
        fi
        sleep 1
    done
    return 1
}

sway_dp_active_count() {
    swaymsg -t get_outputs 2>/dev/null | jq -r '
        [.[] | select(.name | test("^DP-")) | select(.active)
         | select(.current_mode.width // 0 > 0) | select(.dpms == true)] | length' 2>/dev/null || echo 0
}

sway_outputs_healthy() {
    local required="${1:-1}"
    local ready drm_count
    if is_docked; then
        ready="$(sway_dp_active_count)"
        drm_count="$(docked_drm_ports_connected)"
        [[ "$ready" -ge "$required" && "$drm_count" -ge 3 ]]
    else
        ready="$(swaymsg -t get_outputs 2>/dev/null | jq -r '
            [.[] | select(.name == "eDP-1") | select(.active)
             | select(.current_mode.width // 0 > 0) | select(.dpms == true)] | length' 2>/dev/null || echo 0)"
        [[ "$ready" -ge 1 ]]
    fi
}

wait_for_kanshi_outputs() {
    local required="${1:-3}" attempt
    for attempt in $(seq 1 45); do
        if sway_outputs_healthy "$required"; then
            log "kanshi restored ${required} outputs (${attempt}s)"
            return 0
        fi
        (( attempt % 10 == 0 )) && log "waiting for kanshi outputs ($(sway_dp_active_count)/${required}, ${attempt}s)"
        sleep 1
    done
    return 1
}

simulate_dock_replug() {
    local out
    log "simulating dock replug (stop kanshi, cycle DP outputs, restart kanshi)"
    pkill -x kanshi 2>/dev/null || true
    sleep 1
    for out in DP-4 DP-5 DP-6; do
        swaymsg "output $out disable" 2>/dev/null || true
    done
    sleep 5
    swaymsg exec --no-startup-id kanshi 2>/dev/null || true
    wait_for_kanshi_outputs 3 || log "kanshi outputs slow after replug simulation"
}

apply_recovery() {
    local docked=no
    is_docked && docked=yes
    log "apply_recovery (docked=${docked})"
    swaymsg "output * dpms on" 2>/dev/null || true

    if is_docked; then
        simulate_dock_replug
    else
        pkill -x kanshi 2>/dev/null || true
        sleep 1
        swaymsg exec --no-startup-id kanshi 2>/dev/null || true
        wait_for_kanshi_outputs 1 || true
    fi

    if [[ -x "$HOME/.config/kanshi/postswitch.d/10-sway" ]]; then
        SWAYSOCK="${SWAYSOCK:-}" "$HOME/.config/kanshi/postswitch.d/10-sway" 2>/dev/null || true
    fi
    "$HOME/.local/bin/sway-docked-layout" 2>/dev/null || true
    "$HOME/.local/bin/sway-wallpaper" 2>/dev/null || true
    "$HOME/.local/bin/waybar-restart" 2>/dev/null || true
}

wait_for_swaysock || { log "no sway socket; user may be at login screen"; exit 0; }
wait_for_drm || log "drm wait timed out; proceeding anyway"
log "post-DRM settle pause"
sleep 5

required=1
is_docked && required=3

for round in $(seq 1 5); do
    log "recovery round ${round} (need ${required} healthy outputs, have $(sway_dp_active_count))"
    apply_recovery
    sleep 5
    if sway_outputs_healthy "$required"; then
        log "outputs healthy after round ${round}"
        exit 0
    fi
    log "outputs still unhealthy after round ${round}; retrying"
    sleep 10
done

log "outputs still unhealthy; restarting sway so GDM can start a fresh session"
swaymsg exit 2>/dev/null || true
exit 0
