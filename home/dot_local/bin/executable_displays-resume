#!/usr/bin/bash
set -euo pipefail

if [[ "${XDG_SESSION_TYPE:-}" == "wayland" && -n "${SWAYSOCK:-}" ]]; then
    killall -HUP kanshi 2>/dev/null || true
    swaymsg reload 2>/dev/null || true
    "$HOME/.local/bin/sway-docked-layout" 2>/dev/null || true
    "$HOME/.local/bin/sway-wallpaper" 2>/dev/null || true
else
    /usr/bin/sh "$HOME/.screenlayout/main-one-monitor.sh"
    /usr/bin/sh "$HOME/.screenlayout/main.sh"
fi
