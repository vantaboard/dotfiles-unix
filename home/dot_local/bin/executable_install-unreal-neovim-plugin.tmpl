{{ if eq .chezmoi.os "linux" -}}
{{- $p := .profile_example -}}
{{- if index . "profile" -}}{{- $p = .profile -}}{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "unreal" -}}
#!/usr/bin/env bash
set -euo pipefail

ENGINE="${1:-{{ $p.unreal_engine_path | default "" }}}"
UPROJECT="${2:-}"

if [[ -z "$ENGINE" || ! -d "$ENGINE" ]]; then
  echo "Usage: install-unreal-neovim-plugin [engine_path] [project.uproject]" >&2
  exit 1
fi

if [[ -z "$UPROJECT" ]]; then
  UPROJECT="$(find "$PWD" -maxdepth 1 -name '*.uproject' -print -quit)"
fi

if [[ -z "$UPROJECT" || ! -f "$UPROJECT" ]]; then
  echo "No .uproject in cwd; pass path: install-unreal-neovim-plugin [engine] /path/to/Game.uproject" >&2
  exit 1
fi

PROJECT_DIR="$(dirname "$(realpath "$UPROJECT")")"
NVIM_PACK="${NVIM_PACK:-{{ .chezmoi.homeDir }}/.local/share/nvim/site/pack/core/opt/UnrealEngine.nvim}"
PLUGIN_SRC="$NVIM_PACK/Plugins/NeovimSourceCodeAccess/NeovimSourceCodeAccess.uplugin"
UAT="$ENGINE/Engine/Build/BatchFiles/RunUAT.sh"
BUILD_DIR="{{ .chezmoi.homeDir }}/.local/share/nvim/data/unrealengine/NeovimSourceCodeAccess"
INSTALL_DIR="$PROJECT_DIR/Plugins/NeovimSourceCodeAccess"
ENGINE_PLUGIN="$ENGINE/Engine/Plugins/Developer/NeovimSourceCodeAccess"

if [[ ! -f "$PLUGIN_SRC" ]]; then
  echo "UnrealEngine.nvim not installed; open Neovim once to fetch plugins" >&2
  exit 1
fi

if [[ ! -x "$UAT" ]]; then
  echo "RunUAT.sh not found at $UAT" >&2
  exit 1
fi

# Prebuilt engines ship a frozen UE5Rules.dll; engine plugins break UBT for game targets.
if [[ -e "$ENGINE_PLUGIN" ]]; then
  echo "Removing engine-level NeovimSourceCodeAccess (incompatible with prebuilt UE)..."
  rm -rf "$ENGINE_PLUGIN"
fi

echo "Building NeovimSourceCodeAccess via RunUAT BuildPlugin..."
bash "$UAT" BuildPlugin \
  -Plugin="$PLUGIN_SRC" \
  -Package="$BUILD_DIR"

echo "Installing plugin into project Plugins/ (copy, not symlink)..."
rm -rf "$INSTALL_DIR"
cp -a "$BUILD_DIR" "$INSTALL_DIR"

python3 - "$INSTALL_DIR/NeovimSourceCodeAccess.uplugin" "$UPROJECT" <<'PY'
import json
import sys
from pathlib import Path

uplugin = Path(sys.argv[1])
data = json.loads(uplugin.read_text())
data["EnabledByDefault"] = True
uplugin.write_text(json.dumps(data, indent=2) + "\n")
print(f"Patched {uplugin} (EnabledByDefault=true)")

uproject = Path(sys.argv[2])
proj = json.loads(uproject.read_text())
plugins = proj.get("Plugins", [])
if not any(p.get("Name") == "NeovimSourceCodeAccess" for p in plugins):
    plugins.append({"Name": "NeovimSourceCodeAccess", "Enabled": True})
    proj["Plugins"] = plugins
    uproject.write_text(json.dumps(proj, indent="\t") + "\n")
    print(f"Registered NeovimSourceCodeAccess in {uproject}")
PY

LINUX_ENGINE_INI="$ENGINE/Engine/Config/Linux/LinuxEngine.ini"
if [[ -f "$LINUX_ENGINE_INI" ]] && ! grep -q 'Slate.EnableTooltips=False' "$LINUX_ENGINE_INI"; then
  cat >> "$LINUX_ENGINE_INI" <<'EOF'

; Wayland/Sway: tooltips steal focus and break popup clicks (UE 5.7+ SDL3)
[SystemSettings]
Slate.EnableTooltips=False
EOF
  echo "Patched $LINUX_ENGINE_INI (Slate.EnableTooltips=False)" || true
fi

echo "Done. Restart Unreal Editor, then set Source Code Editor to Neovim."
{{- end -}}
{{ end -}}
