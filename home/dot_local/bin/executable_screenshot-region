#!/usr/bin/bash
set -euo pipefail

export PATH="$HOME/.local/bin:/usr/bin:/bin${PATH:+:$PATH}"

grim_bin="$(command -v grim || true)"
slurp_bin="$(command -v slurp || true)"
wl_copy_bin="$(command -v wl-copy || true)"
still_bin="$(command -v still || true)"

if [[ -z "$grim_bin" ]]; then
    echo "screenshot-region: grim is required" >&2
    exit 1
fi
if [[ -z "$slurp_bin" ]]; then
    echo "screenshot-region: slurp is required" >&2
    exit 1
fi
if [[ -z "$wl_copy_bin" ]]; then
    echo "screenshot-region: wl-copy is required" >&2
    exit 1
fi
if [[ -z "$still_bin" ]]; then
    echo "screenshot-region: still is required to freeze the screen during selection" >&2
    exit 1
fi

# still overlays a snapshot and removes it when the inner command exits. hyprpicker
# can leave its layer-shell surface running (especially over fullscreen XWayland apps
# like Chrome), which blocks keyboard and pointer input until SIGKILL.
"$still_bin" -c "bash -c 'geom=\$(\"$slurp_bin\") || exit 1; \"$grim_bin\" -g \"\$geom\" -'" \
    | "$wl_copy_bin" --type image/png || exit 0
