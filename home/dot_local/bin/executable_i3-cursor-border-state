#!/usr/bin/env python3
"""Expose whether focused Cursor is in an i3 tabbed/stacked container."""

from __future__ import annotations

import glob
import os
import socket
import subprocess
import sys
from http.server import BaseHTTPRequestHandler, HTTPServer

PORT = 27182

JQ = r"""
  (.. | objects | select(.focused == true and .window != null)) as $focused |
  if $focused == null then "0"
  elif ($focused.window_properties.class | ascii_downcase) != "cursor" then "0"
  else
    [paths(.. | objects | select(.id == $focused.id))][0] as $p |
    (reduce range(0; ($p | length) - 1) as $i (
      false;
      . or (
        (getpath($p[0:$i+1]) | .layout? // "") as $l |
        $l == "tabbed" or $l == "stacked"
      )
    ) | if . then "1" else "0" end)
  end
"""


def ensure_i3_socket() -> None:
    if os.environ.get("I3SOCK"):
        return
    socks = glob.glob(f"/run/user/{os.getuid()}/i3/ipc-socket.*")
    if socks:
        os.environ["I3SOCK"] = socks[0]


def grouped_state() -> bytes:
    try:
        tree = subprocess.check_output(["i3-msg", "-t", "get_tree"], text=True)
        value = subprocess.check_output(["jq", "-r", JQ], input=tree, text=True).strip()
        return (value or "0").encode()
    except (subprocess.CalledProcessError, FileNotFoundError):
        return b"0"


class Handler(BaseHTTPRequestHandler):
    def do_GET(self) -> None:
        body = grouped_state()
        self.send_response(200)
        self.send_header("Content-Type", "text/plain")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Access-Control-Allow-Origin", "*")
        self.end_headers()
        self.wfile.write(body)

    def log_message(self, fmt: str, *args) -> None:
        pass


def main() -> None:
    ensure_i3_socket()

    probe = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    probe.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
    try:
        probe.bind(("127.0.0.1", PORT))
    except OSError:
        sys.exit(0)
    finally:
        probe.close()

    HTTPServer(("127.0.0.1", PORT), Handler).serve_forever()


if __name__ == "__main__":
    main()
