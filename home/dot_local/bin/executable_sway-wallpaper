#!/usr/bin/bash
set -euo pipefail

declare -a wallpapers=(
    "pexels-pachon-in-motion-426015731-18337644.jpg"
    "pexels-pachon-in-motion-426015731-18545010.jpg"
    "pexels-vahapdmr-18515329.jpg"
)

get_active_outputs() {
    swaymsg -t get_outputs | jq -r '
        .[] | select(.active) | .rect.x as $x | "\($x) \(.name)"' | sort -n | awk '{print $2}'
}

# Active outputs may not be ready yet during sway reload.
outputs=()
for _ in 1 2 3 4 5; do
    mapfile -t outputs < <(get_active_outputs)
    ((${#outputs[@]} > 0)) && break
    sleep 0.2
done

count="${#outputs[@]}"
for (( i=0; i<count; i++ )); do
    wall="${wallpapers[$i]:-${wallpapers[0]}}"
    path="$HOME/.wallpapers/$wall"
    if [[ ! -f "$path" ]]; then
        echo "sway-wallpaper: missing $path" >&2
        continue
    fi
    swaymsg "output ${outputs[$i]} bg $path fill"
done
