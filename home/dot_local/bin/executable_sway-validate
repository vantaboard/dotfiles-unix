#!/usr/bin/bash
set -euo pipefail

pass=0
fail=0

check() {
    local label="$1"
    shift
    if "$@"; then
        echo "PASS: $label"
        pass=$((pass + 1))
    else
        echo "FAIL: $label"
        fail=$((fail + 1))
    fi
}

echo "=== Sway migration validation ==="

check "sway installed" command -v sway
check "swaylock installed" command -v swaylock
check "kanshi installed" command -v kanshi
check "grim installed" command -v grim
check "slurp installed" command -v slurp
check "swappy installed" command -v swappy
check "screenshot-region installed" test -x "$HOME/.local/bin/screenshot-region"
check "suspend installed" test -x "$HOME/.local/bin/suspend"
check "wl-copy installed" command -v wl-copy
check "waybar installed" command -v waybar
check "waybar config exists" test -f "$HOME/.config/waybar/config"
check "waybar-py3status snapshot installed" test -x "$HOME/.local/bin/waybar-py3status-snapshot"
check "py3status config exists" test -f "$HOME/.config/py3status/config"
check "waybar-restart installed" test -x "$HOME/.local/bin/waybar-restart"
check "sway-docked-layout installed" test -x "$HOME/.local/bin/sway-docked-layout"
check "sway config exists" test -f "$HOME/.config/sway/config"
check "kanshi config exists" test -f "$HOME/.config/kanshi/config"
check "swaylock config exists" test -f "$HOME/.config/swaylock/config"
check "wayland env file exists" test -f "$HOME/.config/environment.d/wayland.conf"
check "GDM sway session exists" test -f /usr/share/wayland-sessions/sway.desktop
check "sway-session wrapper installed" test -x /usr/local/bin/sway-session
check "GDM sway desktop uses session wrapper" grep -qF 'Exec=/usr/local/bin/sway-session' /usr/share/wayland-sessions/sway.desktop
if [[ -f /etc/gdm3/custom.conf ]]; then
    check "GDM Wayland enabled" grep -qE '^WaylandEnable=true' /etc/gdm3/custom.conf
    check "GDM default session not forced to X11" \
        bash -c '! grep -qE "^DefaultSession=x11" /etc/gdm3/custom.conf'
else
    echo "INFO: /etc/gdm3/custom.conf not found; skipping GDM Wayland checks"
fi
# Card numbers are not stable across boots; resolve nodes by driver name.
find_card_by_driver() {
    local driver="$1" card node
    for card in /sys/class/drm/card[0-9]*; do
        [[ -e "$card/device/driver" ]] || continue
        [[ "$(basename "$(readlink -f "$card/device/driver")")" == "$driver" ]] || continue
        node="/dev/dri/$(basename "$card")"
        [[ -e "$node" ]] && { echo "$node"; return 0; }
    done
    return 1
}
has_card_with_driver() { find_card_by_driver "$1" >/dev/null; }
check "Intel DRM device exists" has_card_with_driver i915
check "NVIDIA DRM device exists" has_card_with_driver nvidia
check "sway-session resolves GPUs by driver" \
    grep -qF 'find_card_by_driver' /usr/local/bin/sway-session
check "sway-session falls back to Intel without NVIDIA" \
    grep -qF 'export WLR_DRM_DEVICES="$intel_card"' /usr/local/bin/sway-session
if [[ -f "$HOME/.config/kanshi/config" ]]; then
    check "kanshi config syntax" bash -c '
        timeout 0.5 kanshi -c "$HOME/.config/kanshi/config" &
        pid=$!
        sleep 0.2
        if kill -0 "$pid" 2>/dev/null; then
            kill "$pid" 2>/dev/null
            wait "$pid" 2>/dev/null
            exit 0
        fi
        exit 1
    '
fi
check "sway config syntax" bash -c '
    export LD_LIBRARY_PATH="$HOME/.local/lib/x86_64-linux-gnu:$HOME/.local/lib${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}"
    if [[ -x "$HOME/.local/bin/swayfx" ]]; then
        "$HOME/.local/bin/swayfx" -C --unsupported-gpu -c "$HOME/.config/sway/config"
    else
        sway -C --unsupported-gpu -c "$HOME/.config/sway/config"
    fi
'
check "swayfx installed (blur/shadows)" test -x "$HOME/.local/bin/swayfx"
# WLR_RENDERER=vulkan is required on NVIDIA (GLES2/GBM corrupts buffers and
# breaks enabling outputs on the secondary GPU); without vulkan compiled in,
# wlroots silently falls back to GLES2.
wlroots_has_vulkan() {
    local lib
    for lib in "$HOME"/.local/lib/x86_64-linux-gnu/libwlroots-*.so "$HOME"/.local/lib/libwlroots-*.so; do
        [[ -e "$lib" ]] || continue
        ldd "$lib" 2>/dev/null | grep -qi libvulkan && return 0
    done
    return 1
}
check "wlroots built with vulkan renderer" wlroots_has_vulkan
check "kanshi config syntax" grep -q '^profile ' "$HOME/.config/kanshi/config"

if [[ "${XDG_SESSION_TYPE:-}" == "wayland" && -n "${SWAYSOCK:-}" ]]; then
    check "active session is wayland" test "$XDG_SESSION_TYPE" = "wayland"
    wlr_drm_devices_match() {
        local pid val expected nvidia_card intel_card
        pid="$(pgrep -x swayfx | head -1)"
        [[ -z "$pid" ]] && pid="$(pgrep -x sway | head -1)"
        [[ -n "$pid" ]] || return 1
        val="$(tr "\0" "\n" < "/proc/$pid/environ" | sed -n "s/^WLR_DRM_DEVICES=//p")"
        nvidia_card="$(find_card_by_driver nvidia || true)"
        intel_card="$(find_card_by_driver i915 || true)"
        if [[ -n "$nvidia_card" ]]; then
            expected="${nvidia_card}${intel_card:+:${intel_card}}"
        else
            expected="$intel_card"
        fi
        [[ "$val" == "$expected" ]]
    }
    check "WLR_DRM_DEVICES exposes both GPUs" wlr_drm_devices_match
    check "sway IPC responds" swaymsg -t get_version
    check "kanshi running" pgrep -x kanshi
    active_outputs="$(swaymsg -t get_outputs | jq '[.[] | select(.active)] | length')"
    check "at least one active output" test "$active_outputs" -ge 1
else
    echo "INFO: not in an active Sway session; skipping runtime checks"
fi

echo
echo "Results: $pass passed, $fail failed"
echo
echo "Manual checks after logging into Sway from GDM:"
echo "  - Docked 3-monitor layout and undocked eDP switch"
echo "  - Mod+1..8 workspace routing after dock/undock"
echo "  - Mod+d launcher, Mod+Return kitty, swaylock, suspend/resume"
echo "  - screenshot-region (grim/slurp/hyprpicker/wl-copy), rofi-emoji (bemoji), copyq, sunshine, NVIDIA offload apps"
echo "  - waybar sway/language indicator and py3status modules"

if [[ "$fail" -gt 0 ]]; then
    exit 1
fi
