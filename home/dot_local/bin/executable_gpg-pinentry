#!/bin/sh
# Cursor/VS Code pseudo-TTYs report xterm-256color but pinentry-curses fails
# with "Inappropriate ioctl for device". Prefer GUI pinentry when a display
# exists; reserve curses for headless SSH sessions without X/Wayland.
if [ -n "${WAYLAND_DISPLAY:-}" ] || [ -n "${DISPLAY:-}" ]; then
  exec /usr/bin/pinentry-gnome3 "$@"
fi
if [ -t 0 ] && [ -n "${GPG_TTY:-}" ]; then
  exec /usr/bin/pinentry-curses "$@"
fi
exec /usr/bin/pinentry-curses "$@"
