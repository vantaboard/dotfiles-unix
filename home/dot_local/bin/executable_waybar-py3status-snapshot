#!/usr/bin/env python3
"""Return one py3status status snapshot for Waybar."""

import json
import os
import subprocess
import sys


def main() -> None:
    proc = subprocess.Popen(
        ["py3status", "-c", f"{os.environ['HOME']}/.config/py3status/config"],
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
        text=True,
        bufsize=1,
    )
    if proc.stdout is None:
        sys.exit(1)

    proc.stdout.readline()

    parts = []
    for line in proc.stdout:
        line = line.strip()
        if not line or line == "[[":
            continue
        if line.startswith(","):
            line = line[1:]
        try:
            modules = json.loads(line)
        except json.JSONDecodeError:
            continue
        if not isinstance(modules, list):
            continue
        for module in modules:
            if isinstance(module, dict) and module.get("full_text"):
                parts.append(module["full_text"])
        break

    proc.kill()
    proc.wait()
    print(" ".join(parts))


if __name__ == "__main__":
    main()
