{{ if eq .chezmoi.os "android" -}}
#!{{ joinPath (dir .chezmoi.homeDir) "usr/bin/sh" }}
set -eu

# hash: {{ .packages.termux.pkg | toYaml | sha256sum }}
# hash: {{ include ".chezmoidata/pkg-manual.yaml" | sha256sum }}

{{ $p := .profile_termux_example }}
{{ if index . "profile" }}
{{   $p = mergeOverwrite $p .profile }}
{{ end }}
{{ if env "CHEZMOI_CI" }}
{{   $p = .profile_ci }}
{{ end }}
{{ if index . "profile_host" }}
{{   $p = mergeOverwrite $p .profile_host }}
{{ end }}
{{ $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) }}
{{ $f := $p.features }}

# hash: {{ index $f "ollama" }}

if ! command -v pkg >/dev/null 2>&1; then
  echo "pkg not found; not a Termux environment, skipping"
  exit 0
fi

# Termux is rolling-release: installing packages without a full upgrade first
# leaves openssl/libcurl/libngtcp2 out of sync (breaks curl and git-remote-https).
# Use apt directly — it does not depend on curl the way pkg's mirror checks do.
export DEBIAN_FRONTEND=noninteractive
apt update
apt full-upgrade -y \
  -o Dpkg::Options::=--force-confdef \
  -o Dpkg::Options::=--force-confold
apt install -y --no-install-recommends \
{{- range .packages.termux.pkg }}
  {{ . }} \
{{- end }}
{{- if not (env "CHEZMOI_CI") }}
{{- with index . "pkg_manual" }}
{{- with .packages }}
{{- range $pkg, $meta := . }}
{{- if eq $meta.status "install" }}
  {{ $pkg }} \
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- if index $f "ollama" }}
  ollama \
  termux-services \
{{- end }}

echo "Termux packages installed"
{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

# hash: {{ include ".chezmoidata/packages.yaml" | sha256sum }}
# hash: {{ include ".chezmoidata/setup-catalog.yaml" | sha256sum }}
# hash: {{ include ".chezmoidata/profile.example.yaml" | sha256sum }}
# hash: {{ include ".chezmoidata/apt-manual.yaml" | sha256sum }}

{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $aptExclude := default (list) .packages.ubuntu.apt_exclude -}}
{{- $aptExcludeMap := dict -}}
{{- range $aptExclude -}}
{{- $_ := set $aptExcludeMap . true -}}
{{- end -}}
{{- $needsKeyd := false -}}
{{- if not (env "CHEZMOI_CI") -}}
{{- if $p.packages -}}
{{- range $p.packages -}}
{{- if eq . "keyd" -}}{{- $needsKeyd = true -}}{{- end -}}
{{- end -}}
{{- else -}}
{{- range .packages.ubuntu.apt -}}
{{- if eq . "keyd" -}}{{- $needsKeyd = true -}}{{- end -}}
{{- end -}}
{{- end -}}
{{- end }}

if ! command -v apt >/dev/null 2>&1; then
  if [[ -x /usr/bin/apt ]]; then
    export PATH="/usr/bin:/usr/sbin:${PATH:-}"
  else
    echo "apt not found; skipping package installation"
    exit 0
  fi
fi

export DEBIAN_FRONTEND=noninteractive

sudo apt update -qq
{{- if $needsKeyd }}

if ! apt show keyd >/dev/null 2>&1; then
  if command -v add-apt-repository >/dev/null 2>&1; then
    echo "keyd not in default repos; adding ppa:keyd-team/ppa"
    sudo add-apt-repository -y ppa:keyd-team/ppa
    sudo apt update -qq
  else
    echo "WARN: keyd not available and add-apt-repository not found"
  fi
fi
{{- end }}
sudo apt install -y -qq --no-install-recommends \
{{- if env "CHEZMOI_CI" }}
{{- range .packages.ubuntu.apt_ci }}
{{- if not (index $aptExcludeMap .) }}
  {{ . }} \
{{- end }}
{{- end }}
{{- else if $p.packages }}
{{- range $p.packages }}
{{- if not (index $aptExcludeMap .) }}
  {{ . }} \
{{- end }}
{{- end }}
{{- else }}
{{- range .packages.ubuntu.apt }}
{{- if not (index $aptExcludeMap .) }}
  {{ . }} \
{{- end }}
{{- end }}
{{- end }}

echo "core apt packages installed"
{{- if not (env "CHEZMOI_CI") }}
{{- with index . "apt_manual" }}
{{- with .packages }}

# Manually-tracked packages (see scripts/apt-manual-sync). Some originate from
# third-party repos (Docker, Cursor, ngrok, Proton VPN, Huion, ...) that are not
# configured on every host (e.g. WSL). Filter to packages apt can actually
# resolve and install them best-effort so a missing repo never aborts the apply.
manual_pkgs=(
{{- range $pkg, $meta := . }}
{{- if and (eq $meta.status "install") (not (index $aptExcludeMap $pkg)) }}
  {{ $pkg }}
{{- end }}
{{- end }}
)
available_pkgs=()
unavailable_pkgs=()
for pkg in "${manual_pkgs[@]}"; do
  candidate="$(apt-cache policy "$pkg" 2>/dev/null | awk -F': ' '/Candidate:/ {print $2}')" || candidate=""
  if [[ -n "$candidate" && "$candidate" != "(none)" ]]; then
    available_pkgs+=("$pkg")
  else
    unavailable_pkgs+=("$pkg")
  fi
done
if ((${#unavailable_pkgs[@]})); then
  echo "Skipping ${#unavailable_pkgs[@]} manual package(s) with no install candidate (third-party repo not configured?): ${unavailable_pkgs[*]}"
fi
if ((${#available_pkgs[@]})); then
  sudo apt install -y -qq --no-install-recommends "${available_pkgs[@]}" \
    || echo "WARN: one or more manual packages failed to install"
fi
{{- end }}
{{- end }}
{{- end }}

{{- if and (not (env "CHEZMOI_CI")) (index $p.features "desktop_sway") }}
# autorandr (xrandr/X11) conflicts with kanshi on sway Wayland sessions.
if dpkg-query -W -f='${Status}' autorandr 2>/dev/null | grep -q 'install ok installed'; then
  echo "Removing autorandr (conflicts with kanshi on sway Wayland)"
  sudo apt-get remove -y --purge autorandr
fi
{{- end }}

echo "apt packages installed"
{{ end -}}
