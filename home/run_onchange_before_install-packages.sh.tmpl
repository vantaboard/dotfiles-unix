{{ if eq .chezmoi.os "android" -}}
#!{{ joinPath (dir .chezmoi.homeDir) "usr/bin/sh" }}
set -eu

# hash: {{ .packages.termux.pkg | toYaml | sha256sum }}

if ! command -v pkg >/dev/null 2>&1; then
  echo "pkg not found; not a Termux environment, skipping"
  exit 0
fi

pkg install -y \
{{- range .packages.termux.pkg }}
  {{ . }} \
{{- end }}

echo "Termux packages installed"
{{ else if eq .chezmoi.os "linux" -}}
#!/bin/bash
set -euo pipefail

# hash: {{ include ".chezmoidata/setup-catalog.yaml" | sha256sum }}
# hash: {{ include ".chezmoidata/profile.example.yaml" | sha256sum }}
# hash: {{ include ".chezmoidata/apt-manual.yaml" | sha256sum }}

{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}{{- $p = .profile -}}{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- $needsKeyd := false -}}
{{- if not (env "CHEZMOI_CI") -}}
{{- if $p.packages -}}
{{- range $p.packages -}}
{{- if eq . "keyd" -}}{{- $needsKeyd = true -}}{{- end -}}
{{- end -}}
{{- else -}}
{{- range .packages.ubuntu.apt -}}
{{- if eq . "keyd" -}}{{- $needsKeyd = true -}}{{- end -}}
{{- end -}}
{{- end -}}
{{- end }}

if ! command -v apt >/dev/null 2>&1; then
  if [[ -x /usr/bin/apt ]]; then
    export PATH="/usr/bin:/usr/sbin:${PATH:-}"
  else
    echo "apt not found; skipping package installation"
    exit 0
  fi
fi

export DEBIAN_FRONTEND=noninteractive

sudo apt update -qq
{{- if $needsKeyd }}

if ! apt show keyd >/dev/null 2>&1; then
  if command -v add-apt-repository >/dev/null 2>&1; then
    echo "keyd not in default repos; adding ppa:keyd-team/ppa"
    sudo add-apt-repository -y ppa:keyd-team/ppa
    sudo apt update -qq
  else
    echo "WARN: keyd not available and add-apt-repository not found"
  fi
fi
{{- end }}
sudo apt install -y -qq --no-install-recommends \
{{- if env "CHEZMOI_CI" }}
{{- range .packages.ubuntu.apt_ci }}
  {{ . }} \
{{- end }}
{{- else if $p.packages }}
{{- range $p.packages }}
  {{ . }} \
{{- end }}
{{- else }}
{{- range .packages.ubuntu.apt }}
  {{ . }} \
{{- end }}
{{- end }}
{{- if not (env "CHEZMOI_CI") }}
{{- with index . "apt_manual" }}
{{- with .packages }}
{{- range $pkg, $meta := . }}
{{- if eq $meta.status "install" }}
  {{ $pkg }} \
{{- end }}
{{- end }}
{{- end }}
{{- end }}
{{- end }}

echo "apt packages installed"
{{ end -}}
