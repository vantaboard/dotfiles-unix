install_fastfetch() {
  if command -v fastfetch >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "WARN: curl not found; skipping fastfetch install"
    return 0
  fi
  local arch deb url tmp
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64 ;;
    aarch64|arm64) arch=arm64 ;;
    *)
      echo "WARN: unsupported arch for fastfetch deb: $(uname -m)"
      return 0
      ;;
  esac
  deb="fastfetch-linux-${arch}.deb"
  url="https://github.com/fastfetch-cli/fastfetch/releases/latest/download/${deb}"
  tmp="$(mktemp -d)"
  echo "Installing fastfetch from GitHub release (${arch})..."
  if ! curl -fsSL -o "$tmp/$deb" "$url"; then
    echo "WARN: fastfetch deb download failed"
    rm -rf "$tmp"
    return 0
  fi
  sudo dpkg -i "$tmp/$deb" || sudo apt-get install -f -y
  rm -rf "$tmp"
