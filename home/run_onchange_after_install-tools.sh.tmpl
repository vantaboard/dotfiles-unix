install_mise() {
  mise_usable() {
    [[ -n "${1:-}" && -x "$1" ]] && "$1" --version >/dev/null 2>&1
  }

  if mise_usable "$MISE_BIN" || { command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; }; then
    echo "mise already installed"
    return 0
  fi
  if [[ -e "$MISE_BIN" ]]; then
    echo "Removing non-runnable mise binary (wrong OS/arch build)..."
    rm -f "$MISE_BIN"
  fi
{{- if eq .chezmoi.os "android" }}
  echo "Installing mise via Termux package (pkg install mise)..."
  if (apt install -y mise 2>/dev/null || pkg install -y mise 2>/dev/null) \
      && command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; then
    echo "mise installed via Termux package"
    return 0
  fi
  echo "WARN: mise pkg not available (mirror may lag — try termux-change-repo). Skipping; curl install is not supported on Android."
  return 0
{{- else }}
  if ! command -v curl >/dev/null 2>&1; then
    echo "WARN: curl not found; skipping mise install"
    return 0
  fi

  install_mise_from_github() {
    local arch tag url tmp mise_bin
    case "$(uname -m)" in
      x86_64|amd64) arch=x64 ;;
      aarch64|arm64) arch=arm64 ;;
      *)
        echo "WARN: unsupported arch for mise: $(uname -m)"
        return 1
        ;;
    esac
    tag="$(curl -fsSL --retry 3 --retry-delay 2 --retry-all-errors \
      https://api.github.com/repos/jdx/mise/releases/latest \
      | sed -n 's/.*"tag_name": "\([^"]*\)".*/\1/p' | head -1)" || tag=""
    if [[ -z "$tag" ]]; then
      return 1
    fi
    url="https://github.com/jdx/mise/releases/download/${tag}/mise-${tag}-linux-${arch}.tar.gz"
    tmp="$(mktemp -d)"
    echo "Installing mise ${tag} from GitHub (${arch})..."
    if ! curl -fsSL --retry 3 --retry-delay 2 --retry-all-errors "$url" | tar -xz -C "$tmp"; then
      rm -rf "$tmp"
      return 1
    fi
    mise_bin="$(find "$tmp" -type f -name mise | head -1)"
    if [[ -z "$mise_bin" ]]; then
      rm -rf "$tmp"
      return 1
    fi
    mkdir -p "$(dirname "$MISE_BIN")"
    install -m 755 "$mise_bin" "$MISE_BIN"
    rm -rf "$tmp"
    return 0
  }

  if command -v apt >/dev/null 2>&1; then
    candidate="$(apt-cache policy mise 2>/dev/null | awk -F': ' '/Candidate:/ {print $2; exit}' || true)"
    if [[ -n "$candidate" && "$candidate" != "(none)" ]]; then
      echo "Installing mise via apt..."
      if sudo apt install -y -qq --no-install-recommends mise \
          && { mise_usable "$MISE_BIN" || { command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; }; }; then
        echo "mise installed via apt"
        return 0
      fi
      echo "WARN: apt mise install failed; trying other methods..."
    fi
  fi

  echo "Installing mise via mise.run..."
  if curl -fsSL --retry 3 --retry-delay 2 --retry-all-errors https://mise.run | sh; then
    :
  elif install_mise_from_github; then
    :
  else
    echo "WARN: mise install failed (network); skipping — re-run chezmoi apply when connectivity is stable"
    rm -f "$MISE_BIN" 2>/dev/null || true
    return 0
  fi
  if ! mise_usable "$MISE_BIN" && ! { command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; }; then
    echo "WARN: mise install failed"
    rm -f "$MISE_BIN" 2>/dev/null || true
    return 0
  fi
{{- end }}
}

install_fzf_tab() {
  if [[ -d "$FZF_TAB_DIR/.git" ]]; then
    echo "fzf-tab already installed at $FZF_TAB_DIR"
    return 0
  fi
  if [[ ! -d "$HOME_DIR/.oh-my-zsh" ]]; then
    echo "WARN: oh-my-zsh missing; skipping fzf-tab install"
    return 0
  fi
  echo "Installing fzf-tab into OMZ custom plugins..."
  mkdir -p "$ZSH_CUSTOM/plugins"
  git clone https://github.com/Aloxaf/fzf-tab "$FZF_TAB_DIR"
}

install_zsh_abbr() {
  zsh_abbr_ready() {
    [[ -r "$ZSH_ABBR_DIR/zsh-abbr.zsh" && -r "$ZSH_ABBR_JOB_QUEUE" ]]
  }

  if zsh_abbr_ready; then
    echo "zsh-abbr already installed at $ZSH_ABBR_DIR"
    return 0
  fi

  if [[ -d "$ZSH_ABBR_DIR/.git" ]]; then
    echo "Ensuring zsh-abbr submodules (zsh-job-queue)..."
    if git -C "$ZSH_ABBR_DIR" submodule update --init --recursive && zsh_abbr_ready; then
      echo "zsh-abbr submodules ready"
      return 0
    fi
    echo "Incomplete zsh-abbr install; re-cloning..."
    rm -rf "$ZSH_ABBR_DIR"
  elif [[ -d "$ZSH_ABBR_DIR" ]]; then
    rm -rf "$ZSH_ABBR_DIR"
  fi

  echo "Installing zsh-abbr ${ZSH_ABBR_VERSION}..."
  git clone https://github.com/olets/zsh-abbr \
    --recurse-submodules --single-branch --branch "${ZSH_ABBR_VERSION}" \
    "$ZSH_ABBR_DIR"

  if ! zsh_abbr_ready; then
    echo "Retrying zsh-abbr submodule init..."
    git -C "$ZSH_ABBR_DIR" submodule update --init --recursive || true
  fi

  if ! zsh_abbr_ready && [[ -d "$ZSH_ABBR_DIR/.git" ]]; then
    echo "Cloning zsh-job-queue at pinned commit..."
    submodule_commit="$(git -C "$ZSH_ABBR_DIR" ls-tree HEAD zsh-job-queue | awk '{print $3}')"
    rm -rf "$ZSH_ABBR_DIR/zsh-job-queue"
    if [[ -n "$submodule_commit" ]]; then
      git clone https://github.com/olets/zsh-job-queue "$ZSH_ABBR_DIR/zsh-job-queue"
      git -C "$ZSH_ABBR_DIR/zsh-job-queue" checkout "$submodule_commit"
    fi
  fi

  if ! zsh_abbr_ready; then
    echo "WARN: zsh-abbr install incomplete (missing zsh-job-queue); abbr will not load"
    return 0
  fi
  echo "zsh-abbr ready (${ZSH_ABBR_DIR})"
}

{{- if eq .chezmoi.os "android" }}
PSUTIL_VERSION="7.2.2"
PSUTIL_DIR="$HOME_DIR/.local/share/psutil-android"

install_psutil_termux() {
  if "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
    return 0
  fi

  # Optional when the mirror has it (upstream Termux package; not on all mirrors yet).
  if (apt install -y python-psutil 2>/dev/null || pkg install -y python-psutil 2>/dev/null) \
      && python3 -c "import psutil" 2>/dev/null; then
    echo "psutil available via Termux python-psutil package"
    rm -rf "$TRASH_CLI_VENV"
    python3 -m venv --system-site-packages "$TRASH_CLI_VENV"
    "$TRASH_CLI_VENV/bin/pip" install -q -U pip
    if "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
      return 0
    fi
  fi

  echo "Building patched psutil for Termux (pip cannot build unpatched psutil on Android)..."
  if [[ ! -d "$PSUTIL_DIR/.git" ]]; then
    git clone --depth 1 --branch "release-${PSUTIL_VERSION}" \
      https://github.com/giampaolo/psutil "$PSUTIL_DIR"
  fi

  if ! grep -q '"android"' "$PSUTIL_DIR/psutil/_common.py" 2>/dev/null; then
    sed -i 's/LINUX = sys.platform.startswith("linux")/LINUX = sys.platform.startswith(("linux", "android"))/' \
      "$PSUTIL_DIR/psutil/_common.py"
  fi

  if ! command -v clang >/dev/null 2>&1; then
    echo "Installing clang (needed to build psutil)..."
    apt install -y clang 2>/dev/null || pkg install -y clang 2>/dev/null || {
      echo "WARN: clang not available; cannot build psutil"
      return 1
    }
  fi

  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q "$PSUTIL_DIR"
  "$TRASH_CLI_VENV/bin/python" -c "import psutil"
}
{{- end }}

{{- if eq .chezmoi.os "linux" }}
ensure_python3_venv() {
  local probe tmp_venv pyver

  probe() {
    tmp_venv="$(mktemp -d)"
    if python3 -m venv "$tmp_venv" >/dev/null 2>&1; then
      rm -rf "$tmp_venv"
      return 0
    fi
    rm -rf "$tmp_venv"
    return 1
  }

  if probe; then
    return 0
  fi

  if ! command -v apt >/dev/null 2>&1; then
    echo "WARN: python3 venv support missing and apt not available"
    return 1
  fi

  pyver="$(python3 -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null || true)"
  echo "Installing python3-venv (required for trash-cli)..."
  if [[ -n "$pyver" ]]; then
    sudo apt install -y -qq --no-install-recommends "python${pyver}-venv" \
      || sudo apt install -y -qq --no-install-recommends python3-venv
  else
    sudo apt install -y -qq --no-install-recommends python3-venv
  fi

  probe
}
{{- end }}

install_trash_cli() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "WARN: python3 not found; skipping trash-cli install"
    return 0
  fi
  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping trash-cli install"
    return 0
  fi

  if [[ ! -d "$TRASH_CLI_DIR/.git" ]]; then
    echo "Cloning trash-cli into $TRASH_CLI_DIR..."
    git clone https://github.com/andreafrancia/trash-cli "$TRASH_CLI_DIR"
  fi

{{- if eq .chezmoi.os "android" }}
  if [[ -d "$TRASH_CLI_VENV" ]] && ! "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
    echo "Recreating trash-cli venv..."
    rm -rf "$TRASH_CLI_VENV"
  fi

  if [[ ! -d "$TRASH_CLI_VENV" ]]; then
    echo "Creating trash-cli virtualenv..."
    python3 -m venv "$TRASH_CLI_VENV" || {
      echo "WARN: could not create trash-cli virtualenv"
      return 0
    }
  fi

  if ! install_psutil_termux; then
    echo "WARN: psutil not available; skipping trash-cli install"
    return 0
  fi

  echo "Installing trash-cli into venv..."
  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q six
  "$TRASH_CLI_VENV/bin/pip" install -q -e "$TRASH_CLI_DIR" --no-deps
{{- else }}
  if [[ -d "$TRASH_CLI_VENV" ]] && [[ ! -x "$TRASH_CLI_VENV/bin/python" ]]; then
    echo "Removing broken trash-cli venv..."
    rm -rf "$TRASH_CLI_VENV"
  fi

  if [[ ! -d "$TRASH_CLI_VENV" ]]; then
    echo "Creating trash-cli virtualenv..."
    if ! ensure_python3_venv || ! python3 -m venv "$TRASH_CLI_VENV"; then
      echo "WARN: could not create trash-cli virtualenv; install python3-venv and re-run chezmoi apply"
      return 0
    fi
  fi

  echo "Installing trash-cli into venv..."
  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q -e "$TRASH_CLI_DIR"
{{- end }}

  if ! "$TRASH_CLI_VENV/bin/python" -c "import trashcli" 2>/dev/null; then
    echo "WARN: trash-cli install verification failed"
    return 0
  fi

  mkdir -p "$LOCAL_BIN"
  for cmd in "${TRASH_CLI_COMMANDS[@]}"; do
    if [[ -x "$TRASH_CLI_VENV/bin/$cmd" ]]; then
      ln -sf "$TRASH_CLI_VENV/bin/$cmd" "$LOCAL_BIN/$cmd"
    fi
  done
  echo "trash-cli ready (~/.local/bin -> $TRASH_CLI_VENV/bin/*)"
}

install_vivid_linux() {
  if command -v vivid >/dev/null 2>&1; then
    echo "vivid already installed"
    return 0
  fi
  local arch deb url tmp
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64 ;;
    aarch64|arm64) arch=arm64 ;;
    *)
      echo "WARN: unsupported arch for vivid deb: $(uname -m)"
      return 0
      ;;
  esac
  deb="vivid_${VIVID_VERSION}_${arch}.deb"
  url="https://github.com/sharkdp/vivid/releases/download/v${VIVID_VERSION}/${deb}"
  tmp="$(mktemp -d)"
  echo "Installing vivid ${VIVID_VERSION} (${arch})..."
  wget -qO "$tmp/$deb" "$url"
  sudo dpkg -i "$tmp/$deb" || sudo apt-get install -f -y
  rm -rf "$tmp"
}

install_vivid_termux() {
  if command -v vivid >/dev/null 2>&1; then
    echo "vivid already installed"
    return 0
  fi
  if command -v apt >/dev/null 2>&1; then
    apt install -y vivid
  elif command -v pkg >/dev/null 2>&1; then
    pkg install -y vivid
  else
    echo "WARN: no apt/pkg; skipping vivid install"
  fi
}

install_rust() {
  if command -v cargo >/dev/null 2>&1; then
    return 0
  fi
  echo "Installing Rust via rustup..."
  curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path
  # shellcheck disable=SC1091
  [[ -f "$HOME_DIR/.cargo/env" ]] && source "$HOME_DIR/.cargo/env"
}

