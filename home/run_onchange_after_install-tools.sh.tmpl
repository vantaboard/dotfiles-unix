# hash: tools-v19

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping custom tool installs (use apt/pkg packages)"
  exit 0
fi

HOME_DIR="{{ .chezmoi.homeDir }}"
MISE_BIN="$HOME_DIR/.local/bin/mise"
ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME_DIR/.oh-my-zsh/custom}"
FZF_TAB_DIR="$ZSH_CUSTOM/plugins/fzf-tab"
ZSH_ABBR_DIR="$HOME_DIR/zsh-abbr"
ZSH_ABBR_VERSION="v6.3.3"
ZSH_ABBR_JOB_QUEUE="$ZSH_ABBR_DIR/zsh-job-queue/zsh-job-queue.zsh"
TRASH_CLI_DIR="$HOME_DIR/trash-cli"
TRASH_CLI_VENV="$TRASH_CLI_DIR/.venv"
LOCAL_BIN="$HOME_DIR/.local/bin"
LOCAL_PREFIX="$HOME_DIR/.local"
TRASH_CLI_COMMANDS=(trash trash-put trash-empty trash-list trash-restore trash-rm)
VIVID_VERSION="0.10.1"
HYPRPICKER_VERSION="v0.3.0"
HYPRPICKER_DIR="$HOME_DIR/.local/share/src/hyprpicker"
SWAYFX_VERSION="0.5.3"
SCENEFX_VERSION="0.4.1"
WLROOTS_VERSION="0.19.0"
WAYLAND_VERSION="1.23.1"
LIBINPUT_VERSION="1.26.0"
SWAYFX_DIR="$HOME_DIR/.local/share/src/swayfx"
WAYLAND_DIR="$HOME_DIR/.local/share/src/wayland"
LIBINPUT_DIR="$HOME_DIR/.local/share/src/libinput"
LOCAL_PKG_CONFIG="$LOCAL_PREFIX/lib/x86_64-linux-gnu/pkgconfig:$LOCAL_PREFIX/lib/pkgconfig"
SWAPPY_VERSION="v1.5.1"
SWAPPY_DIR="$HOME_DIR/.local/share/src/swappy"

install_mise() {
  mise_usable() {
    [[ -n "${1:-}" && -x "$1" ]] && "$1" --version >/dev/null 2>&1
  }

  if mise_usable "$MISE_BIN" || { command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; }; then
    echo "mise already installed"
    return 0
  fi
  if [[ -e "$MISE_BIN" ]]; then
    echo "Removing non-runnable mise binary (wrong OS/arch build)..."
    rm -f "$MISE_BIN"
  fi
{{- if eq .chezmoi.os "android" }}
  echo "Installing mise via Termux package (pkg install mise)..."
  if (apt install -y mise 2>/dev/null || pkg install -y mise 2>/dev/null) \
      && command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; then
    echo "mise installed via Termux package"
    return 0
  fi
  echo "WARN: mise pkg not available (mirror may lag — try termux-change-repo). Skipping; curl install is not supported on Android."
  return 0
{{- else }}
  if ! command -v curl >/dev/null 2>&1; then
    echo "WARN: curl not found; skipping mise install"
    return 0
  fi
  echo "Installing mise..."
  curl -fsSL https://mise.run | sh
  if ! mise_usable "$MISE_BIN" && ! { command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; }; then
    echo "WARN: mise install failed"
    rm -f "$MISE_BIN" 2>/dev/null || true
    return 0
  fi
{{- end }}
}

install_fzf_tab() {
  if [[ -d "$FZF_TAB_DIR/.git" ]]; then
    echo "fzf-tab already installed at $FZF_TAB_DIR"
    return 0
  fi
  if [[ ! -d "$HOME_DIR/.oh-my-zsh" ]]; then
    echo "WARN: oh-my-zsh missing; skipping fzf-tab install"
    return 0
  fi
  echo "Installing fzf-tab into OMZ custom plugins..."
  mkdir -p "$ZSH_CUSTOM/plugins"
  git clone https://github.com/Aloxaf/fzf-tab "$FZF_TAB_DIR"
}

install_zsh_abbr() {
  zsh_abbr_ready() {
    [[ -r "$ZSH_ABBR_DIR/zsh-abbr.zsh" && -r "$ZSH_ABBR_JOB_QUEUE" ]]
  }

  if zsh_abbr_ready; then
    echo "zsh-abbr already installed at $ZSH_ABBR_DIR"
    return 0
  fi

  if [[ -d "$ZSH_ABBR_DIR/.git" ]]; then
    echo "Ensuring zsh-abbr submodules (zsh-job-queue)..."
    if git -C "$ZSH_ABBR_DIR" submodule update --init --recursive && zsh_abbr_ready; then
      echo "zsh-abbr submodules ready"
      return 0
    fi
    echo "Incomplete zsh-abbr install; re-cloning..."
    rm -rf "$ZSH_ABBR_DIR"
  elif [[ -d "$ZSH_ABBR_DIR" ]]; then
    rm -rf "$ZSH_ABBR_DIR"
  fi

  echo "Installing zsh-abbr ${ZSH_ABBR_VERSION}..."
  git clone https://github.com/olets/zsh-abbr \
    --recurse-submodules --single-branch --branch "${ZSH_ABBR_VERSION}" \
    "$ZSH_ABBR_DIR"

  if ! zsh_abbr_ready; then
    echo "Retrying zsh-abbr submodule init..."
    git -C "$ZSH_ABBR_DIR" submodule update --init --recursive || true
  fi

  if ! zsh_abbr_ready && [[ -d "$ZSH_ABBR_DIR/.git" ]]; then
    echo "Cloning zsh-job-queue at pinned commit..."
    submodule_commit="$(git -C "$ZSH_ABBR_DIR" ls-tree HEAD zsh-job-queue | awk '{print $3}')"
    rm -rf "$ZSH_ABBR_DIR/zsh-job-queue"
    if [[ -n "$submodule_commit" ]]; then
      git clone https://github.com/olets/zsh-job-queue "$ZSH_ABBR_DIR/zsh-job-queue"
      git -C "$ZSH_ABBR_DIR/zsh-job-queue" checkout "$submodule_commit"
    fi
  fi

  if ! zsh_abbr_ready; then
    echo "WARN: zsh-abbr install incomplete (missing zsh-job-queue); abbr will not load"
    return 0
  fi
  echo "zsh-abbr ready (${ZSH_ABBR_DIR})"
}

{{- if eq .chezmoi.os "android" }}
PSUTIL_VERSION="7.2.2"
PSUTIL_DIR="$HOME_DIR/.local/share/psutil-android"

install_psutil_termux() {
  if "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
    return 0
  fi

  # Optional when the mirror has it (upstream Termux package; not on all mirrors yet).
  if (apt install -y python-psutil 2>/dev/null || pkg install -y python-psutil 2>/dev/null) \
      && python3 -c "import psutil" 2>/dev/null; then
    echo "psutil available via Termux python-psutil package"
    rm -rf "$TRASH_CLI_VENV"
    python3 -m venv --system-site-packages "$TRASH_CLI_VENV"
    "$TRASH_CLI_VENV/bin/pip" install -q -U pip
    if "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
      return 0
    fi
  fi

  echo "Building patched psutil for Termux (pip cannot build unpatched psutil on Android)..."
  if [[ ! -d "$PSUTIL_DIR/.git" ]]; then
    git clone --depth 1 --branch "release-${PSUTIL_VERSION}" \
      https://github.com/giampaolo/psutil "$PSUTIL_DIR"
  fi

  if ! grep -q '"android"' "$PSUTIL_DIR/psutil/_common.py" 2>/dev/null; then
    sed -i 's/LINUX = sys.platform.startswith("linux")/LINUX = sys.platform.startswith(("linux", "android"))/' \
      "$PSUTIL_DIR/psutil/_common.py"
  fi

  if ! command -v clang >/dev/null 2>&1; then
    echo "Installing clang (needed to build psutil)..."
    apt install -y clang 2>/dev/null || pkg install -y clang 2>/dev/null || {
      echo "WARN: clang not available; cannot build psutil"
      return 1
    }
  fi

  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q "$PSUTIL_DIR"
  "$TRASH_CLI_VENV/bin/python" -c "import psutil"
}
{{- end }}

install_trash_cli() {
  if ! command -v python3 >/dev/null 2>&1; then
    echo "WARN: python3 not found; skipping trash-cli install"
    return 0
  fi
  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping trash-cli install"
    return 0
  fi

  if [[ ! -d "$TRASH_CLI_DIR/.git" ]]; then
    echo "Cloning trash-cli into $TRASH_CLI_DIR..."
    git clone https://github.com/andreafrancia/trash-cli "$TRASH_CLI_DIR"
  fi

{{- if eq .chezmoi.os "android" }}
  if [[ -d "$TRASH_CLI_VENV" ]] && ! "$TRASH_CLI_VENV/bin/python" -c "import psutil" 2>/dev/null; then
    echo "Recreating trash-cli venv..."
    rm -rf "$TRASH_CLI_VENV"
  fi

  if [[ ! -d "$TRASH_CLI_VENV" ]]; then
    echo "Creating trash-cli virtualenv..."
    python3 -m venv "$TRASH_CLI_VENV"
  fi

  if ! install_psutil_termux; then
    echo "WARN: psutil not available; skipping trash-cli install"
    return 0
  fi

  echo "Installing trash-cli into venv..."
  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q six
  "$TRASH_CLI_VENV/bin/pip" install -q -e "$TRASH_CLI_DIR" --no-deps
{{- else }}
  if [[ ! -d "$TRASH_CLI_VENV" ]]; then
    echo "Creating trash-cli virtualenv..."
    python3 -m venv "$TRASH_CLI_VENV"
  fi

  echo "Installing trash-cli into venv..."
  "$TRASH_CLI_VENV/bin/pip" install -q -U pip
  "$TRASH_CLI_VENV/bin/pip" install -q -e "$TRASH_CLI_DIR"
{{- end }}

  if ! "$TRASH_CLI_VENV/bin/python" -c "import trashcli" 2>/dev/null; then
    echo "WARN: trash-cli install verification failed"
    return 0
  fi

  mkdir -p "$LOCAL_BIN"
  for cmd in "${TRASH_CLI_COMMANDS[@]}"; do
    if [[ -x "$TRASH_CLI_VENV/bin/$cmd" ]]; then
      ln -sf "$TRASH_CLI_VENV/bin/$cmd" "$LOCAL_BIN/$cmd"
    fi
  done
  echo "trash-cli ready (~/.local/bin -> $TRASH_CLI_VENV/bin/*)"
}

install_vivid_linux() {
  if command -v vivid >/dev/null 2>&1; then
    echo "vivid already installed"
    return 0
  fi
  local arch deb url tmp
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64 ;;
    aarch64|arm64) arch=arm64 ;;
    *)
      echo "WARN: unsupported arch for vivid deb: $(uname -m)"
      return 0
      ;;
  esac
  deb="vivid_${VIVID_VERSION}_${arch}.deb"
  url="https://github.com/sharkdp/vivid/releases/download/v${VIVID_VERSION}/${deb}"
  tmp="$(mktemp -d)"
  echo "Installing vivid ${VIVID_VERSION} (${arch})..."
  wget -qO "$tmp/$deb" "$url"
  sudo dpkg -i "$tmp/$deb" || sudo apt-get install -f -y
  rm -rf "$tmp"
}

install_vivid_termux() {
  if command -v vivid >/dev/null 2>&1; then
    echo "vivid already installed"
    return 0
  fi
  if command -v apt >/dev/null 2>&1; then
    apt install -y vivid
  elif command -v pkg >/dev/null 2>&1; then
    pkg install -y vivid
  else
    echo "WARN: no apt/pkg; skipping vivid install"
  fi
}

install_rust() {
  if command -v cargo >/dev/null 2>&1; then
    return 0
  fi
  echo "Installing Rust via rustup..."
  curl -fsSL https://sh.rustup.rs | sh -s -- -y --no-modify-path
  # shellcheck disable=SC1091
  [[ -f "$HOME_DIR/.cargo/env" ]] && source "$HOME_DIR/.cargo/env"
}

install_zoxide() {
  if command -v zoxide >/dev/null 2>&1; then
    return 0
  fi
  echo "Installing zoxide..."
  cargo install zoxide
}

{{- if eq .chezmoi.os "linux" }}
install_hyprpicker() {
  hyprpicker_usable() {
    command -v hyprpicker >/dev/null 2>&1 && hyprpicker --help >/dev/null 2>&1
  }

  if hyprpicker_usable || [[ -x "$LOCAL_BIN/hyprpicker" ]]; then
    echo "hyprpicker already installed"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping hyprpicker install"
    return 0
  fi
  if ! command -v cmake >/dev/null 2>&1; then
    echo "WARN: cmake not found; skipping hyprpicker install"
    return 0
  fi

  local cxx_compiler=c++
  if command -v g++-14 >/dev/null 2>&1; then
    cxx_compiler=g++-14
  fi

  local build_deps=(
    cmake pkg-config libpango1.0-dev libcairo2-dev libwayland-dev
    wayland-protocols libxkbcommon-dev libjpeg-dev "g++"
  )
  if [[ "$cxx_compiler" == "g++-14" ]]; then
    build_deps+=(gcc-14 g++-14)
  fi

  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing hyprpicker build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  if [[ "$cxx_compiler" == "g++-14" ]] && command -v g++-14 >/dev/null 2>&1; then
    export CC=gcc-14 CXX=g++-14
  fi

  mkdir -p "$LOCAL_BIN"

  if [[ ! -d "$HYPRPICKER_DIR/.git" ]]; then
    echo "Cloning hyprpicker ${HYPRPICKER_VERSION}..."
    git clone --depth 1 --branch "$HYPRPICKER_VERSION" \
      https://github.com/hyprwm/hyprpicker "$HYPRPICKER_DIR"
  else
    git -C "$HYPRPICKER_DIR" fetch --depth 1 origin tag "$HYPRPICKER_VERSION" 2>/dev/null || true
    git -C "$HYPRPICKER_DIR" checkout "$HYPRPICKER_VERSION" 2>/dev/null || true
  fi

  echo "Building hyprpicker ${HYPRPICKER_VERSION} with ${CXX:-$cxx_compiler}..."
  cmake --no-warn-unused-cli \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="$LOCAL_PREFIX" \
    -DCMAKE_C_COMPILER="${CC:-cc}" \
    -DCMAKE_CXX_COMPILER="${CXX:-$cxx_compiler}" \
    -S "$HYPRPICKER_DIR" -B "$HYPRPICKER_DIR/build"
  cmake --build "$HYPRPICKER_DIR/build" --config Release --target hyprpicker \
    -j"$(nproc 2>/dev/null || getconf _NPROCESSORS_CONF)"

  if ! cmake --install "$HYPRPICKER_DIR/build" 2>/dev/null; then
    install -m 755 "$HYPRPICKER_DIR/build/hyprpicker" "$LOCAL_BIN/hyprpicker"
  fi

  if hyprpicker_usable || [[ -x "$LOCAL_BIN/hyprpicker" ]]; then
    echo "hyprpicker ready ($LOCAL_BIN/hyprpicker)"
  else
    echo "WARN: hyprpicker install failed"
    return 0
  fi
}

install_swayfx() {
  swayfx_usable() {
    [[ -x "$LOCAL_BIN/swayfx" ]] && "$LOCAL_BIN/swayfx" --version 2>/dev/null | grep -qi swayfx
  }

  pkg_version_ge() {
    local pkg="$1" min="$2"
    local ver
    ver="$(PKG_CONFIG_PATH="$LOCAL_PKG_CONFIG${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
      pkg-config --modversion "$pkg" 2>/dev/null || true)"
    [[ -n "$ver" ]] || return 1
    [[ "$(printf '%s\n%s\n' "$min" "$ver" | sort -V | head -1)" == "$min" ]]
  }

  ensure_local_wayland() {
    pkg_version_ge wayland-server 1.23.1 && return 0
    if ! command -v git >/dev/null 2>&1 || ! command -v meson >/dev/null 2>&1; then
      echo "WARN: need git/meson to build wayland ${WAYLAND_VERSION} for swayfx"
      return 1
    fi
    if [[ ! -f "$WAYLAND_DIR/meson.build" ]]; then
      rm -rf "$WAYLAND_DIR"
      echo "Cloning wayland ${WAYLAND_VERSION}..."
      git clone --depth 1 --branch "$WAYLAND_VERSION" \
        https://gitlab.freedesktop.org/wayland/wayland.git "$WAYLAND_DIR"
    fi
    echo "Building wayland ${WAYLAND_VERSION} into ${LOCAL_PREFIX}..."
    meson setup "$WAYLAND_DIR/build" "$WAYLAND_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Ddocumentation=false \
      --reconfigure 2>/dev/null \
      || meson setup "$WAYLAND_DIR/build" "$WAYLAND_DIR" \
        --prefix="$LOCAL_PREFIX" \
        --buildtype=release \
        -Ddocumentation=false
    ninja -C "$WAYLAND_DIR/build"
    ninja -C "$WAYLAND_DIR/build" install
  }

  ensure_local_libinput() {
    pkg_version_ge libinput 1.26.0 && return 0
    if ! command -v git >/dev/null 2>&1 || ! command -v meson >/dev/null 2>&1; then
      echo "WARN: need git/meson to build libinput ${LIBINPUT_VERSION} for swayfx"
      return 1
    fi
    if [[ ! -f "$LIBINPUT_DIR/meson.build" ]]; then
      rm -rf "$LIBINPUT_DIR"
      echo "Cloning libinput ${LIBINPUT_VERSION}..."
      git clone --depth 1 --branch "$LIBINPUT_VERSION" \
        https://gitlab.freedesktop.org/libinput/libinput.git "$LIBINPUT_DIR"
    fi
    echo "Building libinput ${LIBINPUT_VERSION} into ${LOCAL_PREFIX}..."
    meson setup "$LIBINPUT_DIR/build" "$LIBINPUT_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Ddocumentation=false \
      -Ddebug=false \
      -Dtests=false \
      --reconfigure 2>/dev/null \
      || meson setup "$LIBINPUT_DIR/build" "$LIBINPUT_DIR" \
        --prefix="$LOCAL_PREFIX" \
        --buildtype=release \
        -Ddocumentation=false \
        -Ddebug=false \
        -Dtests=false
    ninja -C "$LIBINPUT_DIR/build"
    ninja -C "$LIBINPUT_DIR/build" install
  }

  if swayfx_usable; then
    echo "swayfx already installed"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping swayfx install"
    return 0
  fi
  if ! command -v meson >/dev/null 2>&1 || ! command -v ninja >/dev/null 2>&1; then
    echo "WARN: meson/ninja not found; skipping swayfx install"
    return 0
  fi

  local build_deps=(
    meson ninja-build pkg-config cmake git scdoc
    wayland-protocols libwayland-dev libpcre2-dev libjson-c-dev
    libpango1.0-dev libcairo2-dev libgdk-pixbuf-2.0-dev
    libdrm-dev libgbm-dev libinput-dev libseat-dev libxkbcommon-dev
    libxcb-dri3-dev libxcb-present-dev libxcb-res0-dev
    libxcb-render-util0-dev libxcb-ewmh-dev libxcb-icccm4-dev
    libliftoff-dev libdisplay-info-dev liblcms2-dev libpixman-1-dev
    libgles2-mesa-dev libudev-dev libevdev-dev libmtdev-dev libwacom-dev
  )
  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing swayfx build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  mkdir -p "$LOCAL_BIN" "$LOCAL_PREFIX/lib"

  ensure_local_wayland || return 0
  ensure_local_libinput || return 0

  export PKG_CONFIG_PATH="$LOCAL_PKG_CONFIG${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
  export PATH="$LOCAL_BIN:$PATH"

  if [[ ! -f "$SWAYFX_DIR/meson.build" ]]; then
    rm -rf "$SWAYFX_DIR"
  fi

  if [[ ! -d "$SWAYFX_DIR/.git" ]]; then
    echo "Cloning swayfx ${SWAYFX_VERSION}..."
    git clone --depth 1 --branch "$SWAYFX_VERSION" \
      https://github.com/WillPower3309/swayfx.git "$SWAYFX_DIR"
  else
    git -C "$SWAYFX_DIR" fetch --depth 1 origin tag "$SWAYFX_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR" checkout "$SWAYFX_VERSION" 2>/dev/null || true
  fi

  mkdir -p "$SWAYFX_DIR/subprojects"

  if [[ ! -d "$SWAYFX_DIR/subprojects/scenefx/.git" ]]; then
    echo "Cloning scenefx ${SCENEFX_VERSION}..."
    git clone --depth 1 --branch "$SCENEFX_VERSION" \
      https://github.com/wlrfx/scenefx.git "$SWAYFX_DIR/subprojects/scenefx"
  else
    git -C "$SWAYFX_DIR/subprojects/scenefx" fetch --depth 1 origin tag "$SCENEFX_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR/subprojects/scenefx" checkout "$SCENEFX_VERSION" 2>/dev/null || true
  fi

  if [[ ! -d "$SWAYFX_DIR/subprojects/wlroots/.git" ]]; then
    echo "Cloning wlroots ${WLROOTS_VERSION}..."
    git clone --depth 1 --branch "$WLROOTS_VERSION" \
      https://gitlab.freedesktop.org/wlroots/wlroots.git "$SWAYFX_DIR/subprojects/wlroots"
  else
    git -C "$SWAYFX_DIR/subprojects/wlroots" fetch --depth 1 origin tag "$WLROOTS_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR/subprojects/wlroots" checkout "$WLROOTS_VERSION" 2>/dev/null || true
  fi

  echo "Building swayfx ${SWAYFX_VERSION} into ${LOCAL_PREFIX}..."
  if [[ -d "$SWAYFX_DIR/build/meson-private" ]]; then
    meson setup "$SWAYFX_DIR/build" "$SWAYFX_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Dwerror=false \
      --reconfigure
  else
    meson setup "$SWAYFX_DIR/build" "$SWAYFX_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Dwerror=false
  fi
  ninja -C "$SWAYFX_DIR/build"
  ninja -C "$SWAYFX_DIR/build" install

  if [[ -x "$LOCAL_BIN/sway" && ! -e "$LOCAL_BIN/swayfx" ]]; then
    mv "$LOCAL_BIN/sway" "$LOCAL_BIN/swayfx"
  fi

  if swayfx_usable; then
    echo "swayfx ready ($LOCAL_BIN/swayfx)"
  else
    echo "WARN: swayfx install failed"
    return 0
  fi
}

install_swappy() {
  swappy_usable() {
    command -v swappy >/dev/null 2>&1 && swappy --version >/dev/null 2>&1
  }

  if swappy_usable || [[ -x "$LOCAL_BIN/swappy" ]]; then
    echo "swappy already installed"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping swappy install"
    return 0
  fi
  if ! command -v meson >/dev/null 2>&1 || ! command -v ninja >/dev/null 2>&1; then
    echo "WARN: meson/ninja not found; skipping swappy install"
    return 0
  fi

  local build_deps=(
    meson ninja-build libgtk-3-dev libpango1.0-dev libcairo2-dev
  )
  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing swappy build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  mkdir -p "$LOCAL_BIN"

  if [[ ! -d "$SWAPPY_DIR/.git" ]]; then
    echo "Cloning swappy ${SWAPPY_VERSION}..."
    git clone --depth 1 --branch "$SWAPPY_VERSION" \
      https://github.com/jtheoof/swappy "$SWAPPY_DIR"
  else
    git -C "$SWAPPY_DIR" fetch --depth 1 origin tag "$SWAPPY_VERSION" 2>/dev/null || true
    git -C "$SWAPPY_DIR" checkout "$SWAPPY_VERSION" 2>/dev/null || true
  fi

  echo "Building swappy ${SWAPPY_VERSION}..."
  meson setup "$SWAPPY_DIR/build" "$SWAPPY_DIR" \
    --prefix="$LOCAL_PREFIX" --reconfigure 2>/dev/null \
    || meson setup "$SWAPPY_DIR/build" "$SWAPPY_DIR" --prefix="$LOCAL_PREFIX"
  ninja -C "$SWAPPY_DIR/build"
  ninja -C "$SWAPPY_DIR/build" install

  if swappy_usable || [[ -x "$LOCAL_BIN/swappy" ]]; then
    echo "swappy ready ($LOCAL_BIN/swappy)"
  else
    echo "WARN: swappy install failed"
    return 0
  fi
}
{{- end }}

