install_wayneko() {
  wayneko_usable() {
    command -v wayneko >/dev/null 2>&1 && wayneko --help >/dev/null 2>&1
  }

  if wayneko_usable || [[ -x "$LOCAL_BIN/wayneko" ]]; then
    echo "wayneko already installed"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping wayneko install"
    return 0
  fi
  if ! command -v make >/dev/null 2>&1 || ! command -v pkg-config >/dev/null 2>&1; then
    echo "WARN: make/pkg-config not found; skipping wayneko install"
    return 0
  fi
  if ! command -v wayland-scanner >/dev/null 2>&1; then
    echo "WARN: wayland-scanner not found; skipping wayneko install"
    return 0
  fi

  local build_deps=(
    build-essential pkg-config libpixman-1-dev libwayland-dev libwayland-bin
  )
  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing wayneko build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  mkdir -p "$LOCAL_BIN"

  if [[ ! -d "$WAYNEKO_DIR/.git" ]]; then
    echo "Cloning wayneko ${WAYNEKO_COMMIT}..."
    git clone https://git.sr.ht/~leon_plickat/wayneko "$WAYNEKO_DIR"
  fi
  # Pin to last good commit: upstream master was force-pushed to a broken
  # "slop check" that references a nonexistent FFI_VERSION_NUMBER macro.
  git -C "$WAYNEKO_DIR" fetch --depth 1 origin "$WAYNEKO_COMMIT"
  git -C "$WAYNEKO_DIR" checkout --force "$WAYNEKO_COMMIT"

  echo "Building wayneko ${WAYNEKO_COMMIT}..."
  make -C "$WAYNEKO_DIR" clean >/dev/null 2>&1 || true
  # Prefer gcc: clang inherits -Werror and trips on pointer-type mismatches
  # in Wayland listener tables (same issue nixpkgs patches around).
  make -C "$WAYNEKO_DIR" CC=gcc -j"$(nproc 2>/dev/null || getconf _NPROCESSORS_CONF)"
  make -C "$WAYNEKO_DIR" PREFIX="$LOCAL_PREFIX" install

  if wayneko_usable || [[ -x "$LOCAL_BIN/wayneko" ]]; then
    echo "wayneko ready ($LOCAL_BIN/wayneko)"
  else
    install -m 755 "$WAYNEKO_DIR/wayneko" "$LOCAL_BIN/wayneko"
    if wayneko_usable || [[ -x "$LOCAL_BIN/wayneko" ]]; then
      echo "wayneko ready ($LOCAL_BIN/wayneko)"
    else
      echo "WARN: wayneko install failed"
      return 0
    fi
  fi
}

install_swayfx() {
  SWAYFX_HIDE_CURSOR_PATCH="$HOME_DIR/.local/share/patches/swayfx-hide-cursor-keep-active.patch"

  swayfx_lib_path() {
    printf '%s' "$LOCAL_PREFIX/lib/x86_64-linux-gnu:$LOCAL_PREFIX/lib"
  }

  swayfx_usable() {
    [[ -x "$LOCAL_BIN/swayfx" ]] || return 1
    LD_LIBRARY_PATH="$(swayfx_lib_path)${LD_LIBRARY_PATH:+:$LD_LIBRARY_PATH}" \
      "$LOCAL_BIN/swayfx" --version 2>/dev/null | grep -qi swayfx
  }

  # sway-session sets WLR_RENDERER=vulkan (NVIDIA GLES2/GBM corrupts buffers
  # and breaks multi-GPU output enable), so wlroots must be built with the
  # Vulkan renderer — without it wlroots silently falls back to GLES2.
  swayfx_has_vulkan() {
    local lib
    for lib in "$LOCAL_PREFIX"/lib/x86_64-linux-gnu/libwlroots-*.so "$LOCAL_PREFIX"/lib/libwlroots-*.so; do
      [[ -e "$lib" ]] || continue
      ldd "$lib" 2>/dev/null | grep -qi libvulkan && return 0
    done
    return 1
  }

  swayfx_hide_cursor_patched() {
    [[ -f "$SWAYFX_DIR/sway/input/cursor.c" ]] || return 1
    ! grep -q 'wlr_seat_pointer_notify_clear_focus(cursor->seat->wlr_seat)' \
      "$SWAYFX_DIR/sway/input/cursor.c"
  }

  apply_swayfx_hide_cursor_patch() {
    if swayfx_hide_cursor_patched; then
      return 0
    fi
    if [[ ! -f "$SWAYFX_HIDE_CURSOR_PATCH" ]]; then
      echo "WARN: missing $SWAYFX_HIDE_CURSOR_PATCH; hide_cursor will drop hover state"
      return 1
    fi
    echo "Applying swayfx hide-cursor keep-active patch..."
    if ! patch -d "$SWAYFX_DIR" -p1 -N --forward < "$SWAYFX_HIDE_CURSOR_PATCH"; then
      echo "WARN: failed to apply hide-cursor patch"
      return 1
    fi
    rm -rf "$SWAYFX_DIR/build"
  }

  pkg_version_ge() {
    local pkg="$1" min="$2"
    local ver
    ver="$(PKG_CONFIG_PATH="$LOCAL_PKG_CONFIG${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}" \
      pkg-config --modversion "$pkg" 2>/dev/null || true)"
    [[ -n "$ver" ]] || return 1
    [[ "$(printf '%s\n%s\n' "$min" "$ver" | sort -V | head -1)" == "$min" ]]
  }

  ensure_local_wayland() {
    pkg_version_ge wayland-server 1.23.1 && return 0
    if ! command -v git >/dev/null 2>&1 || ! command -v meson >/dev/null 2>&1; then
      echo "WARN: need git/meson to build wayland ${WAYLAND_VERSION} for swayfx"
      return 1
    fi
    if [[ ! -f "$WAYLAND_DIR/meson.build" ]]; then
      rm -rf "$WAYLAND_DIR"
      echo "Cloning wayland ${WAYLAND_VERSION}..."
      git clone --depth 1 --branch "$WAYLAND_VERSION" \
        https://gitlab.freedesktop.org/wayland/wayland.git "$WAYLAND_DIR"
    fi
    echo "Building wayland ${WAYLAND_VERSION} into ${LOCAL_PREFIX}..."
    meson setup "$WAYLAND_DIR/build" "$WAYLAND_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Ddocumentation=false \
      --reconfigure 2>/dev/null \
      || meson setup "$WAYLAND_DIR/build" "$WAYLAND_DIR" \
        --prefix="$LOCAL_PREFIX" \
        --buildtype=release \
        -Ddocumentation=false
    ninja -C "$WAYLAND_DIR/build"
    ninja -C "$WAYLAND_DIR/build" install
  }

  ensure_local_libinput() {
    pkg_version_ge libinput 1.26.0 && return 0
    if ! command -v git >/dev/null 2>&1 || ! command -v meson >/dev/null 2>&1; then
      echo "WARN: need git/meson to build libinput ${LIBINPUT_VERSION} for swayfx"
      return 1
    fi
    if [[ ! -f "$LIBINPUT_DIR/meson.build" ]]; then
      rm -rf "$LIBINPUT_DIR"
      echo "Cloning libinput ${LIBINPUT_VERSION}..."
      git clone --depth 1 --branch "$LIBINPUT_VERSION" \
        https://gitlab.freedesktop.org/libinput/libinput.git "$LIBINPUT_DIR"
    fi
    echo "Building libinput ${LIBINPUT_VERSION} into ${LOCAL_PREFIX}..."
    meson setup "$LIBINPUT_DIR/build" "$LIBINPUT_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Ddocumentation=false \
      -Ddebug=false \
      -Dtests=false \
      --reconfigure 2>/dev/null \
      || meson setup "$LIBINPUT_DIR/build" "$LIBINPUT_DIR" \
        --prefix="$LOCAL_PREFIX" \
        --buildtype=release \
        -Ddocumentation=false \
        -Ddebug=false \
        -Dtests=false
    ninja -C "$LIBINPUT_DIR/build"
    ninja -C "$LIBINPUT_DIR/build" install
  }

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping swayfx install"
    return 0
  fi
  if ! command -v meson >/dev/null 2>&1 || ! command -v ninja >/dev/null 2>&1; then
    echo "WARN: meson/ninja not found; skipping swayfx install"
    return 0
  fi

  local build_deps=(
    meson ninja-build pkg-config cmake git scdoc
    wayland-protocols libwayland-dev libpcre2-dev libjson-c-dev
    libpango1.0-dev libcairo2-dev libgdk-pixbuf-2.0-dev
    libdrm-dev libgbm-dev libinput-dev libseat-dev libxkbcommon-dev
    libxcb-dri3-dev libxcb-present-dev libxcb-res0-dev
    libxcb-render-util0-dev libxcb-ewmh-dev libxcb-icccm4-dev
    libliftoff-dev libdisplay-info-dev liblcms2-dev libpixman-1-dev
    libgles2-mesa-dev libudev-dev libevdev-dev libmtdev-dev libwacom-dev
    libvulkan-dev glslang-tools
  )
  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing swayfx build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  mkdir -p "$LOCAL_BIN" "$LOCAL_PREFIX/lib"

  ensure_local_wayland || return 0
  ensure_local_libinput || return 0

  export PKG_CONFIG_PATH="$LOCAL_PKG_CONFIG${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
  export PATH="$LOCAL_BIN:$PATH"

  if [[ ! -f "$SWAYFX_DIR/meson.build" ]]; then
    rm -rf "$SWAYFX_DIR"
  fi

  if [[ ! -d "$SWAYFX_DIR/.git" ]]; then
    echo "Cloning swayfx ${SWAYFX_VERSION}..."
    git clone --depth 1 --branch "$SWAYFX_VERSION" \
      https://github.com/WillPower3309/swayfx.git "$SWAYFX_DIR"
  else
    git -C "$SWAYFX_DIR" fetch --depth 1 origin tag "$SWAYFX_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR" checkout "$SWAYFX_VERSION" 2>/dev/null || true
  fi

  apply_swayfx_hide_cursor_patch || true

  if swayfx_usable && swayfx_hide_cursor_patched && swayfx_has_vulkan; then
    echo "swayfx already installed (hide-cursor keep-active, vulkan renderer)"
    return 0
  fi

  mkdir -p "$SWAYFX_DIR/subprojects"

  if [[ ! -d "$SWAYFX_DIR/subprojects/scenefx/.git" ]]; then
    echo "Cloning scenefx ${SCENEFX_VERSION}..."
    git clone --depth 1 --branch "$SCENEFX_VERSION" \
      https://github.com/wlrfx/scenefx.git "$SWAYFX_DIR/subprojects/scenefx"
  else
    git -C "$SWAYFX_DIR/subprojects/scenefx" fetch --depth 1 origin tag "$SCENEFX_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR/subprojects/scenefx" checkout "$SCENEFX_VERSION" 2>/dev/null || true
  fi

  if [[ ! -d "$SWAYFX_DIR/subprojects/wlroots/.git" ]]; then
    echo "Cloning wlroots ${WLROOTS_VERSION}..."
    git clone --depth 1 --branch "$WLROOTS_VERSION" \
      https://gitlab.freedesktop.org/wlroots/wlroots.git "$SWAYFX_DIR/subprojects/wlroots"
  else
    git -C "$SWAYFX_DIR/subprojects/wlroots" fetch --depth 1 origin tag "$WLROOTS_VERSION" 2>/dev/null || true
    git -C "$SWAYFX_DIR/subprojects/wlroots" checkout "$WLROOTS_VERSION" 2>/dev/null || true
  fi

  echo "Building swayfx ${SWAYFX_VERSION} into ${LOCAL_PREFIX}..."
  if [[ -d "$SWAYFX_DIR/build/meson-private" ]]; then
    if ! meson setup "$SWAYFX_DIR/build" "$SWAYFX_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Dwerror=false \
      -Dwlroots:renderers=gles2,vulkan \
      --reconfigure 2>/dev/null; then
      echo "Reconfigure failed; wiping build dir and starting fresh..."
      rm -rf "$SWAYFX_DIR/build"
    fi
  fi
  if [[ ! -d "$SWAYFX_DIR/build/meson-private" ]]; then
    meson setup "$SWAYFX_DIR/build" "$SWAYFX_DIR" \
      --prefix="$LOCAL_PREFIX" \
      --buildtype=release \
      -Dwerror=false \
      -Dwlroots:renderers=gles2,vulkan
  fi
  ninja -C "$SWAYFX_DIR/build"
  ninja -C "$SWAYFX_DIR/build" install

  if [[ -x "$LOCAL_BIN/sway" ]]; then
    install -m 755 "$LOCAL_BIN/sway" "$LOCAL_BIN/swayfx"
    rm -f "$LOCAL_BIN/sway"
  fi

  if swayfx_usable; then
    if swayfx_has_vulkan; then
      echo "swayfx ready ($LOCAL_BIN/swayfx, vulkan renderer)"
    else
      echo "WARN: swayfx built without vulkan renderer; NVIDIA GLES2 fallback is broken"
    fi
  else
    echo "WARN: swayfx install failed"
    return 0
  fi
}

