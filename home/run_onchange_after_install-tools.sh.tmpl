install_gh() {
  if command -v gh >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "WARN: curl not found; skipping gh install"
    return 0
  fi
  local arch tag ver url tmp gh_bin
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64 ;;
    aarch64|arm64) arch=arm64 ;;
    *)
      echo "WARN: unsupported arch for gh: $(uname -m)"
      return 0
      ;;
  esac
  tag="$(curl -fsSL https://api.github.com/repos/cli/cli/releases/latest \
    | sed -n 's/.*"tag_name": "\([^"]*\)".*/\1/p' | head -1)"
  if [[ -z "$tag" ]]; then
    echo "WARN: could not resolve latest gh release"
    return 0
  fi
  ver="${tag#v}"
  url="https://github.com/cli/cli/releases/download/${tag}/gh_${ver}_linux_${arch}.tar.gz"
  tmp="$(mktemp -d)"
  echo "Installing gh ${tag} (${arch})..."
  if ! curl -fsSL "$url" | tar -xz -C "$tmp"; then
    echo "WARN: gh download failed"
    rm -rf "$tmp"
    return 0
  fi
  gh_bin="$(find "$tmp" -type f -name gh -path '*/bin/gh' | head -1)"
  if [[ -z "$gh_bin" ]]; then
    echo "WARN: gh binary not found in archive"
    rm -rf "$tmp"
    return 0
  fi
  mkdir -p "$LOCAL_BIN"
  install -m 755 "$gh_bin" "$LOCAL_BIN/gh"
  rm -rf "$tmp"
}

install_glab() {
  if command -v glab >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v curl >/dev/null 2>&1; then
    echo "WARN: curl not found; skipping glab install"
    return 0
  fi
  local arch tag ver url tmp glab_bin
  case "$(uname -m)" in
    x86_64|amd64) arch=amd64 ;;
    aarch64|arm64) arch=arm64 ;;
    *)
      echo "WARN: unsupported arch for glab: $(uname -m)"
      return 0
      ;;
  esac
  tag="$(curl -fsSL 'https://gitlab.com/api/v4/projects/gitlab-org%2Fcli/releases?per_page=1' \
    | sed -n 's/.*"tag_name":"\([^"]*\)".*/\1/p' | head -1)"
  if [[ -z "$tag" ]]; then
    echo "WARN: could not resolve latest glab release"
    return 0
  fi
  ver="${tag#v}"
  url="https://gitlab.com/gitlab-org/cli/-/releases/${tag}/downloads/glab_${ver}_linux_${arch}.tar.gz"
  tmp="$(mktemp -d)"
  echo "Installing glab ${tag} (${arch})..."
  if ! curl -fsSL "$url" | tar -xz -C "$tmp"; then
    echo "WARN: glab download failed"
    rm -rf "$tmp"
    return 0
  fi
  glab_bin="$(find "$tmp" -type f -name glab -path '*/bin/glab' | head -1)"
  if [[ -z "$glab_bin" ]]; then
    echo "WARN: glab binary not found in archive"
    rm -rf "$tmp"
    return 0
  fi
  mkdir -p "$LOCAL_BIN"
  install -m 755 "$glab_bin" "$LOCAL_BIN/glab"
  rm -rf "$tmp"
}

{{- if eq .chezmoi.os "linux" }}
install_hyprpicker() {
  hyprpicker_usable() {
    command -v hyprpicker >/dev/null 2>&1 && hyprpicker --help >/dev/null 2>&1
  }

  if hyprpicker_usable || [[ -x "$LOCAL_BIN/hyprpicker" ]]; then
    echo "hyprpicker already installed"
    return 0
  fi

  if ! command -v git >/dev/null 2>&1; then
    echo "WARN: git not found; skipping hyprpicker install"
    return 0
  fi
  if ! command -v cmake >/dev/null 2>&1; then
    echo "WARN: cmake not found; skipping hyprpicker install"
    return 0
  fi

  local cxx_compiler=c++
  if command -v g++-14 >/dev/null 2>&1; then
    cxx_compiler=g++-14
  fi

  local build_deps=(
    cmake pkg-config libpango1.0-dev libcairo2-dev libwayland-dev
    wayland-protocols libxkbcommon-dev libjpeg-dev "g++"
  )
  if [[ "$cxx_compiler" == "g++-14" ]]; then
    build_deps+=(gcc-14 g++-14)
  fi

  local dep missing=()
  if command -v dpkg >/dev/null 2>&1; then
    for dep in "${build_deps[@]}"; do
      if ! dpkg -s "$dep" >/dev/null 2>&1; then
        missing+=("$dep")
      fi
    done
    if [[ ${#missing[@]} -gt 0 ]]; then
      echo "Installing hyprpicker build dependencies: ${missing[*]}"
      sudo apt install -y -qq --no-install-recommends "${missing[@]}"
    fi
  fi

  if [[ "$cxx_compiler" == "g++-14" ]] && command -v g++-14 >/dev/null 2>&1; then
    export CC=gcc-14 CXX=g++-14
  fi

  mkdir -p "$LOCAL_BIN"

  if [[ ! -d "$HYPRPICKER_DIR/.git" ]]; then
    echo "Cloning hyprpicker ${HYPRPICKER_VERSION}..."
    git clone --depth 1 --branch "$HYPRPICKER_VERSION" \
      https://github.com/hyprwm/hyprpicker "$HYPRPICKER_DIR"
  else
    git -C "$HYPRPICKER_DIR" fetch --depth 1 origin tag "$HYPRPICKER_VERSION" 2>/dev/null || true
    git -C "$HYPRPICKER_DIR" checkout "$HYPRPICKER_VERSION" 2>/dev/null || true
  fi

  echo "Building hyprpicker ${HYPRPICKER_VERSION} with ${CXX:-$cxx_compiler}..."
  cmake --no-warn-unused-cli \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX="$LOCAL_PREFIX" \
    -DCMAKE_C_COMPILER="${CC:-cc}" \
    -DCMAKE_CXX_COMPILER="${CXX:-$cxx_compiler}" \
    -S "$HYPRPICKER_DIR" -B "$HYPRPICKER_DIR/build"
  cmake --build "$HYPRPICKER_DIR/build" --config Release --target hyprpicker \
    -j"$(nproc 2>/dev/null || getconf _NPROCESSORS_CONF)"

  if ! cmake --install "$HYPRPICKER_DIR/build" 2>/dev/null; then
    install -m 755 "$HYPRPICKER_DIR/build/hyprpicker" "$LOCAL_BIN/hyprpicker"
  fi

  if hyprpicker_usable || [[ -x "$LOCAL_BIN/hyprpicker" ]]; then
    echo "hyprpicker ready ($LOCAL_BIN/hyprpicker)"
  else
    echo "WARN: hyprpicker install failed"
    return 0
  fi
}

