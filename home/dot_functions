function parse_query() {
    QUERY=$1

    for p in ${QUERY//&/ };do kvp=( ${p/=/ } ); k=${kvp[0]};v=${kvp[1]};eval $k=$v;done
}

function cpmeta() {
    from=$1
    to=$2
    extension=$(echo "$from" | rev | cut -d'.' -f1 | rev)
    
    ffmpeg -i "$from" -f ffmetadata meta.txt  
    ffmpeg -i "$to" -i meta.txt -map_metadata 1 -codec copy "tmp_copied_final.$extension"
    mv -f "tmp_copied_final.$extension" "$to"
    rm meta.txt
}

kitty-reload() {
    kill -SIGUSR1 $(pidof kitty)
}

function ldiff() {
    # $ ldiff a.csv b.csv
    # > 235
    # > 623 a.csv 
    # > 123 b.csv

    usage() {
        echo 
        echo Usage: ldiff file_a file_b
        kill -INT $$
    }

    fatal() {
        echo error: $*
        usage 1
    }

    [ "$1" = -h ] && usage 0

    [ $# -lt 1 ] && fatal file_a is missing
    [ $# -lt 2 ] && fatal file_b is missing. Needs two files to diff

    alen=$(cat $1 | wc -l)
    blen=$(cat $2 | wc -l)
    dlen=$(diff -U 0 $1 $2 | grep ^@ | wc -l)

    echo $dlen
    echo $alen $1
    echo $blen $2
}

function pdf_shotgun() {
    $1

    find . -type f -name "*.pdf" | shuf -n $1 | xargs -I {} open "{}"
}

function zshcompile() {
    # Compile frequently sourced scripts to .zwc if they exist
    zmodload zsh/zcompile 2>/dev/null || return

    # list of glob patterns to compile; patterns may match 0 files
    typeset -a _compile_globs=(
      "$ZSH/oh-my-zsh.sh"
      "$ZSH/lib/*.zsh"
      "$ZSH/plugins/git/git.plugin.zsh"
      "$HOME/.config/zsh/*.zsh"
      "$ZSH/custom/plugins/zsh-completions/src/*.zsh"
    )

    setopt localoptions null_glob             # missing globs -> empty list
    typeset -a _to_compile=()

    for pat in "${_compile_globs[@]}"; do
      for f in $~pat; do                      # expand pattern safely
        [[ -r $f ]] && _to_compile+="$f"
      done
    done

    if (( ${#_to_compile} )); then
      # one .zwc per file keeps sourcing behavior simple
      for f in "${_to_compile[@]}"; do
        zcompile -R "${f}.zwc" "$f"
      done
      echo "Compiled ${#_to_compile} files."
    else
      echo "Nothing to compile."
    fi
}

screenkey-dev() {
  local screen="$1"
  local height=80   # height of the screenkey banner

  if [[ -z "$screen" ]]; then
    echo "usage: screenkey-dev <SCREEN_INDEX>"
    return 1
  fi

  # Extract geometry for the given screen index from xrandr
  # Format we want: WIDTHxHEIGHT+X+Y
  local geom
  geom=$(
    xrandr --listmonitors \
      | awk -v s="$screen" '
          $1 == s ":" {
            # example line:
            # 1: +HDMI-1 1920/509x1080/286+3008+0  HDMI-1
            match($0, /([0-9]+)\/[0-9]+x([0-9]+)\/[0-9]+\+([0-9]+)\+([0-9]+)/, a)
            if (a[1] && a[2]) {
              print a[1] "x" a[2] "+" a[3] "+" a[4]
            }
          }
        '
  )

  if [[ -z "$geom" ]]; then
    echo "Could not determine geometry for screen $screen"
    xrandr --listmonitors
    return 1
  fi

  # Replace height with our desired banner height, keep X/Y offset
  local width x y
  IFS='x+' read -r width _ x y <<< "$geom"
  local final_geom="${width}x${height}+${x}+${y}"

  screenkey \
    --position fixed \
    --geometry "$final_geom" \
    --timeout 2 \
    --opacity 0.9 \
    --bg-color "#000000" \
    --font-size large
}

