#!/usr/bin/bash

function compabbr() {
    local abbr_file="${XDG_CONFIG_HOME:-$HOME/.config}/zsh-abbr/user-abbreviations"
    # Compile once (run this manually whenever you edit the abbr file)
    zmodload zsh/zcompile
    zcompile -R "${abbr_file}{.zwc,.zwc.old}"

    # .zshrc
    [[ -r "${abbr_file}.zwc" ]] && source "${abbr_file}.zwc" || source "$abbr_file"
}

abbr() {
  command abbr "$@"
  # only sync when abbr was mutated; you can refine flags here
  case "$*" in
    *"-a"*|*"add"*|*"remove"*|*"-r"*) nohup ~/.local/bin/zsh-abbr-sync >/dev/null 2>&1 & ;;
  esac
}

function reload_abbr() {
    ABBR_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/zsh-abbr/user-abbreviations"
    [[ -f "$ABBR_FILE" ]] && source "$ABBR_FILE"
}

function gmr() {
    current_branch=$(git rev-parse --abbrev-ref HEAD)
    default_branch=${1:-$(git symbolic-ref refs/remotes/origin/HEAD | sed 's@^refs/remotes/origin/@@')}

    glab mr create --fill --squash-before-merge --source-branch $current_branch --target-branch $default_branch -y
}

function gitlab-path() {
    PROJECT_ROOT=$(git remote get-url origin | grep -oP '(?<=:).+(?=\.git)')
    PROJECT_BRANCH=$(git branch --show-current)

    echo "https://gitlab.com/$PROJECT_ROOT/-/tree/$PROJECT_BRANCH"
}

function commit() {
    route=$1
    hash=$2
    echo "https://github.com/$route/commit/$hash" | xclip -selection clipboard
}

function whatport() {
    sudo lsof -i :"$1"
}

# Toggle bare-repo dotfiles git (~/.cfg, work tree $HOME). Do not export these globally
# (e.g. in .zshenv) or every repo will look like $HOME.
function move_to_config_env {
    if [ "$1" = "on" ]; then
        export GIT_DIR=$HOME/.cfg
        export GIT_WORK_TREE=$HOME
        return
    fi

    if [ "$1" = "off" ]; then
        unset GIT_DIR
        unset GIT_WORK_TREE
        return
    fi
}

# recursively replace line in all files
function recrep() {
    FROM=$1
    TO=$2
    EXT=$3

    if [ "$EXT" = "" ]; then
        find . -type f -print0 | xargs -0 sed -i '' -e "s/$FROM/$TO/g"
    else
        find . -type f -name "*.$EXT" -print0 | xargs -0 sed -i '' -e "s/$FROM/$TO/g"
    fi
}

function catless() {
    output=$(cat "$1")
    nvim_commands=()

    filename=$(echo "$1" | sed -E 's/ /_/g' | sed -E 's/[^a-zA-Z0-9_\-\.]//g')
    hash=$(date +%s%3N | base64)

    ext=$(echo "$filename" | rev | cut -d'.' -f1 | rev)

    if [ "$ext" = "json" ]; then
        output=$("$output" | jq .)
    fi

    mkdir -p ~/.nvim-less-cache/"$hash"
    echo "$output" > ~/.nvim-less-cache/"$hash"/"$filename"
    nvim_commands+=(nvim -R ~/.nvim-less-cache/"$hash"/"$filename")


    if [[ "$filename" == diff* ]]; then
        nvim_commands+=(-c "'set filetype=diff'")
    fi

    "${nvim_commands[@]}"
}

