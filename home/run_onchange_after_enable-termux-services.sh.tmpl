{{ if eq .chezmoi.os "android" -}}
#!{{ joinPath (dir .chezmoi.homeDir) "usr/bin/bash" }}
set -euo pipefail

# hash: termux-services-v3

{{ $p := .profile_termux_example }}
{{ if index . "profile" }}
{{   $p = mergeOverwrite $p .profile }}
{{ end }}
{{ if env "CHEZMOI_CI" }}
{{   $p = .profile_ci }}
{{ end }}
{{ if index . "profile_host" }}
{{   $p = mergeOverwrite $p .profile_host }}
{{ end }}
{{ $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) }}
{{ $f := $p.features }}

# hash: {{ index $f "llama" }}

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping Termux service setup"
  exit 0
fi

if ! command -v pkg >/dev/null 2>&1; then
  echo "Not Termux; skipping Termux service setup"
  exit 0
fi

LLAMA_FEATURE={{ if index $f "llama" }}1{{ else }}0{{ end }}
if [[ "$LLAMA_FEATURE" != "1" ]] && ! command -v llama-server >/dev/null 2>&1; then
  echo "llama-cpp not installed and feature disabled; skipping Termux service setup"
  exit 0
fi

PREFIX="${PREFIX:-{{ dir .chezmoi.homeDir }}/usr}"
HOME_DIR="{{ .chezmoi.homeDir }}"
export SVDIR="${SVDIR:-$PREFIX/var/service}"
export LOGDIR="${LOGDIR:-$PREFIX/var/log}"
SH_BIN="$PREFIX/bin/sh"
SERVICE_DIR="$SVDIR/llama-server"
RUN_SCRIPT="$SERVICE_DIR/run"
START_SERVICES="$PREFIX/etc/profile.d/start-services.sh"
MODEL_PATH="$HOME_DIR/.local/share/llama.cpp/models/coder.gguf"
LISTEN_PORT=9292

install_termux_services() {
  if command -v sv >/dev/null 2>&1 && command -v service-daemon >/dev/null 2>&1; then
    return 0
  fi
  if ! command -v apt >/dev/null 2>&1; then
    echo "WARN: termux-services not installed. Run: pkg install termux-services"
    return 1
  fi
  echo "Installing termux-services for runit service management..."
  apt install -y termux-services
}

ensure_service_daemon() {
  if pgrep -f '[r]unsvdir' >/dev/null 2>&1; then
    return 0
  fi
  if [[ -f "$START_SERVICES" ]]; then
    # shellcheck source=/dev/null
    . "$START_SERVICES"
  elif command -v service-daemon >/dev/null 2>&1; then
    service-daemon start
  else
    echo "WARN: runsvdir not running and start-services.sh missing"
    return 1
  fi
  local i
  for i in $(seq 1 20); do
    if pgrep -f '[r]unsvdir' >/dev/null 2>&1; then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

wait_for_supervise() {
  local path="$1"
  local i
  for i in $(seq 1 20); do
    if [[ -e "$path/supervise/ok" ]]; then
      return 0
    fi
    sleep 0.5
  done
  return 1
}

llama_service_running() {
  sv status llama-server 2>/dev/null | grep -q 'run: llama-server: (pid [0-9]'
}

setup_llama_service() {
  if ! command -v llama-server >/dev/null 2>&1; then
    echo "WARN: llama feature enabled but llama-server not installed (pkg install llama-cpp)"
    return 0
  fi

  if [[ ! -f "$MODEL_PATH" ]]; then
    echo "WARN: coder model missing at $MODEL_PATH; run chezmoi apply after models download"
  fi

  if ! install_termux_services; then
    return 0
  fi

  mkdir -p "$SERVICE_DIR/log"
  local new_service=false
  if [[ ! -x "$RUN_SCRIPT" ]]; then
    new_service=true
  fi
  cat > "$RUN_SCRIPT" << EOF
#!$SH_BIN
exec llama-server \\
  --host 127.0.0.1 \\
  --port ${LISTEN_PORT} \\
  --model "$MODEL_PATH" \\
  -ngl 99 \\
  -fa \\
  -c 8192 \\
  --cache-reuse 256
EOF
  chmod 700 "$RUN_SCRIPT"
  if [[ -e "$PREFIX/share/termux-services/svlogger" ]]; then
    ln -sfn "$PREFIX/share/termux-services/svlogger" "$SERVICE_DIR/log/run"
  fi
  if [[ "$new_service" == true ]]; then
    : > "$SERVICE_DIR/down"
  fi

  # Retire legacy Ollama service if present.
  if [[ -d "$SVDIR/ollama" ]]; then
    sv down ollama 2>/dev/null || true
    rm -f "$SVDIR/ollama/down" 2>/dev/null || true
  fi

  if ! ensure_service_daemon; then
    echo "WARN: runsvdir not running. Restart Termux, then: sv-enable llama-server && sv up llama-server"
    return 0
  fi

  wait_for_supervise "$SERVICE_DIR" || true

  if command -v sv-enable >/dev/null 2>&1; then
    sv-enable llama-server
  else
    rm -f "$SERVICE_DIR/down"
  fi

  wait_for_supervise "$SERVICE_DIR" || sleep 2
  sv up llama-server 2>/dev/null || true
  wait_for_supervise "$SERVICE_DIR/log" || true
  sv up llama-server 2>/dev/null || true

  if llama_service_running; then
    echo "llama-server running on 127.0.0.1:${LISTEN_PORT} (sv status llama-server)"
  else
    echo "llama-server service files installed but not running yet."
    echo "  Restart Termux, then run: sv-enable llama-server && sv up llama-server"
    echo "  Logs: $PREFIX/var/log/sv/llama-server/current"
  fi
}

setup_llama_service
{{ end -}}
