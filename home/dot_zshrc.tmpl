{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
{{- if index $f "p10k" }}
{{- if env "CHEZMOI_CI" }}
export POWERLEVEL9K_INSTANT_PROMPT=off
{{- else }}
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi
{{- end }}
{{- end }}

##### ─────────────────────────────────────────────────────────────────────────────
##### RUN FIRST: single-pass, cached completion init (no audit), correct order
##### ─────────────────────────────────────────────────────────────────────────────

{{- if index $f "oh_my_zsh" }}
# Ensure completion dirs are available *before* compinit runs
{{- if index $f "zsh_completions" }}
fpath+=${ZSH_CUSTOM:-${ZSH:-$HOME/.oh-my-zsh}/custom}/plugins/zsh-completions/src
{{- end }}
{{- end }}

# Prevent Debian/Ubuntu global rc from running compinit early
export skip_global_compinit=1

# Make OMZ skip its compfix (which triggers compaudit)
export ZSH_DISABLE_COMPFIX=true

# Use a fast compdump in XDG cache
export ZSH_COMPDUMP="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/.zcompdump-${ZSH_VERSION}"
mkdir -p -- "${ZSH_COMPDUMP:h}"

# Extra completion dirs must be on fpath *before* compinit builds the dump
# (e.g. cursor-clip drops completions here).
fpath+=("$HOME/.local/share/zsh/site-functions")

# Run compinit once. Trust the cached dump (-C, no audit) for a fast startup,
# but do a full rebuild when the dump is missing or older than a day so newly
# installed completions get picked up without needing a second compinit pass.
# The match is captured via array assignment (not [[ … ]]) so the bare glob
# qualifier works without requiring the extended_glob option to be set here.
autoload -Uz compinit
_zcompdump_stale=("$ZSH_COMPDUMP"(N.mh+24))
if (( $#_zcompdump_stale )); then
  compinit -u -d "$ZSH_COMPDUMP"
else
  compinit -C -u -d "$ZSH_COMPDUMP"
fi
unset _zcompdump_stale

# Completion styles
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path "${XDG_CACHE_HOME:-$HOME/.cache}/zsh/compcache"
zstyle ':completion:*' rehash false

# disable sort when completing `git checkout`
zstyle ':completion:*:git-checkout:*' sort false
# set descriptions format to enable group support
# NOTE: don't use escape sequences (like '%F{red}%d%f') here, fzf-tab will ignore them
zstyle ':completion:*:descriptions' format '[%d]'
# set list-colors to enable filename colorizing
zstyle ':completion:*' list-colors ${(s.:.)LS_COLORS}
# force zsh not to show completion menu, which allows fzf-tab to capture the unambiguous prefix
zstyle ':completion:*' menu no

##### ─────────────────────────────────────────────────────────────────────────────
##### Manually installed plugins (source *before* OMZ is fine with the guard)
##### ─────────────────────────────────────────────────────────────────────────────

{{- if index $f "zsh_edit" }}
# zsh-edit
[[ -r "$HOME/.zshplugins/zsh-edit/zsh-edit.plugin.zsh" ]] && source "$HOME/.zshplugins/zsh-edit/zsh-edit.plugin.zsh"
{{- end }}

{{- if index $f "fzf" }}
# Git fzf must precede OMZ/plugin init — distro fzf is too old for ~/.fzf bindings.
export PATH="{{ .chezmoi.homeDir }}/.fzf/bin:$PATH"
# If you also have ~/.fzf.zsh and want it after zvm init (harmless if var unset)
zvm_after_init_commands+=('[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh')
{{- end }}

##### ─────────────────────────────────────────────────────────────────────────────
##### Oh My Zsh core
##### ─────────────────────────────────────────────────────────────────────────────

{{- if index $f "oh_my_zsh" }}
export ZSH="$HOME/.oh-my-zsh"

# OMZ / plugin settings
{{- if index $f "zsh_autosuggestions" }}
export ZSH_AUTOSUGGEST_HIGHLIGHT_STYLE="fg=#868888,bold"
export ZSH_AUTOSUGGEST_MANUAL_REBIND=true
{{- end }}
{{- if index $f "p10k" }}
export ZSH_THEME="powerlevel10k/powerlevel10k"
{{- end }}
export DISABLE_UNTRACKED_FILES_DIRTY="true"
export HYPHEN_INSENSITIVE="true"
export MENU_COMPLETE="true"
export DISABLE_AUTO_UPDATE=true
export DISABLE_UPDATE_PROMPT="true"
export DIRSTACKSIZE=100000000000000000
export DISABLE_MAGIC_FUNCTIONS=true

export PATH="$PATH:{KREW_ROOT:-$HOME/.krew}/bin:$HOME/.local/bin:$HOME/.local/share/gem/ruby/3.0.0/bin:/var/lib/flatpak/exports/share:$HOME/.local/share/flatpak/exports/share:$HOME/go/bin:$HOME/kde/usr/bin:$HOME/.istioctl/bin:/opt/depot_tools:/usr/local/go/bin:$HOME/.cargo/bin:$HOME/Code/splatmoji/"

plugins=({{- if index $f "omz_codeclimate" }}codeclimate {{ end -}}{{- if index $f "omz_extract" }}extract {{ end -}}{{- if index $f "omz_python" }}python {{ end -}}{{- if index $f "omz_virtualenv" }}virtualenv {{ end -}}{{- if index $f "zsh_autosuggestions" }}zsh-autosuggestions {{ end -}}{{- if index $f "omz_ssh_agent" }}ssh-agent {{ end -}}{{- if index $f "omz_fzf" }}fzf {{ end -}}{{- if index $f "fzf_tab" }}fzf-tab {{ end -}}{{- if index $f "omz_git" }}git{{ end }})

# OMZ bootstrap (now safe—compinit/compaudit are already handled)
source "$ZSH/oh-my-zsh.sh"

{{- if index $f "fzf_tab" }}
# preview directory's content with eza when completing cd
zstyle ':fzf-tab:complete:cd:*' fzf-preview 'eza -1 --color=always $realpath'
# custom fzf flags
# NOTE: fzf-tab does not follow FZF_DEFAULT_OPTS by default
zstyle ':fzf-tab:*' fzf-flags --color=fg:1,fg+:2 --bind=tab:accept
# To make fzf-tab follow FZF_DEFAULT_OPTS.
# NOTE: This may lead to unexpected behavior since some flags break this plugin. See Aloxaf/fzf-tab#455.
zstyle ':fzf-tab:*' use-fzf-default-opts yes
# switch group using `<` and `>`
zstyle ':fzf-tab:*' switch-group '<' '>'
{{- end }}
{{- end }}

##### ─────────────────────────────────────────────────────────────────────────────
##### Lazy-load abbreviations
##### ─────────────────────────────────────────────────────────────────────────────

{{- if index $f "zsh_abbr" }}
export ABBR_AUTOLOAD=0
export ABBR_USER_ABBREVIATIONS_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/zsh-abbr/user-abbreviations"
autoload -Uz add-zsh-hook
_abbr_lazy_load() {
  add-zsh-hook -d precmd _abbr_lazy_load
  [[ -r "$HOME/zsh-abbr/zsh-abbr.zsh" ]] && source "$HOME/zsh-abbr/zsh-abbr.zsh"
}
add-zsh-hook precmd _abbr_lazy_load
{{- end }}

##### ─────────────────────────────────────────────────────────────────────────────
##### Source your dotfiles bundle
##### ─────────────────────────────────────────────────────────────────────────────

declare -a files=(
  "export"
  "env"
  "functions"
  "alias"
  "alias-git"
  "bindings"
  "inputrc"
{{- if index $f "fzf" }}
  "fzf.zsh"
{{- end }}
)

source_files() {
  local files=("$@")
  for file in "${files[@]}"; do
    [[ -r "$HOME/.$file" ]] && source "$HOME/.$file"
  done
}
source_files "${files[@]}"

##### ─────────────────────────────────────────────────────────────────────────────
##### History settings
##### ─────────────────────────────────────────────────────────────────────────────

setopt inc_append_history     # write to history immediately
setopt share_history          # share history across sessions
setopt extended_history       # save timestamp/duration
setopt hist_ignoredups        # skip duplicate commands

##### ─────────────────────────────────────────────────────────────────────────────
##### keychain, GPG
##### ─────────────────────────────────────────────────────────────────────────────

{{- if index $f "gpg_signing" }}
# gpg-agent prompts on the controlling TTY (see ~/.gnupg/gpg-agent.conf).
if tty -s; then
  export GPG_TTY="$(tty)"
  gpg-connect-agent updatestartuptty /bye >/dev/null 2>&1
fi

# GPG signing via keychain. Invoking `keychain` on every shell is slow (~400ms)
# because it re-validates gpg-agent each time. The agent persists across shells,
# so source the cached agent env and only run keychain when the agent isn't
# already up (e.g. the first shell after boot). ${HOST} avoids spawning
# hostname(1), and --no-autostart means the check itself won't launch an agent.
if [[ -n "$GIT_GPG_KEY" ]]; then
  _keychain_env="$HOME/.keychain/${HOST}-sh-gpg"
  [[ -r "$_keychain_env" ]] && source "$_keychain_env"
  if ! gpg-connect-agent --no-autostart /bye >/dev/null 2>&1; then
    eval "$(keychain --quiet --eval --agents gpg "$GIT_GPG_KEY" 2>/dev/null)"
    [[ -r "$_keychain_env" ]] && source "$_keychain_env"
  fi
  unset _keychain_env
fi
{{- end }}

##### ─────────────────────────────────────────────────────────────────────────────
##### Optional: manual recompile helper (run only when you change files)
##### ─────────────────────────────────────────────────────────────────────────────

recompile_zsh() {
  autoload -Uz zrecompile
  setopt localoptions null_glob
  local globs=(
    "$ZSH/oh-my-zsh.sh"
    "$ZSH/lib/*.zsh"
    "$ZSH/plugins/git/git.plugin.zsh"
    "$HOME/.zshplugins/zsh-edit/*.zsh"
    "$HOME/.{export,env,functions,alias,alias-git,bindings,inputrc,fzf.zsh}"
  )
  local f
  for f in ${^globs}; do
    [[ -r "$f" ]] && zrecompile -p "$f"
  done
  echo "Recompiled."
}

##### ─────────────────────────────────────────────────────────────────────────────
##### Profiling (optional)
##### ─────────────────────────────────────────────────────────────────────────────

# Comment out when you're done profiling
# zprof

{{- if index $f "zoxide" }}
# Must be set *before* the init line above if you want it to apply there too,
# but it's fine after if you only care about manual calls like the widget below.
export _ZO_FZF_OPTS="--height 40% --layout=reverse --info=inline"

if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh --cmd cd)"
fi

__zox_fzf_cd_widget() {
  setopt localoptions no_shwordsplit
  zle -I  # clear pending keys

  local dir
  local exit_code

  # Use the real TTY for input so Ctrl-C cancels fzf itself
  dir="$(zoxide query -i </dev/tty 2>/dev/tty)"
  exit_code=$?

  # Ctrl-C inside fzf: just repaint a clean prompt (no literal $PROMPT echo)
  if (( exit_code == 130 )); then
    BUFFER=''            # ensure nothing remains on the line
    zle reset-prompt
    zle redisplay
    return 0
  fi

  # Esc or other nonzero → repaint and bail
  if (( exit_code != 0 )); then
    zle reset-prompt
    zle redisplay

    zle accept-line
    return 0
  fi

  [[ -n $dir ]] || { zle reset-prompt; zle redisplay; return 0; }

  # Jump immediately
  builtin cd -- "$dir" || return
  zoxide add -- "$dir" &>/dev/null
  zle reset-prompt
  zle redisplay
}

zle -N __zox_fzf_cd_widget
bindkey '^U' __zox_fzf_cd_widget
bindkey -M viins '^U' __zox_fzf_cd_widget
bindkey -M vicmd '^U' __zox_fzf_cd_widget
{{- end }}

{{- if index $f "p10k" }}
# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
{{- end }}

{{- if index $f "clang" }}
export CC=clang
export CXX=clang++
{{- end }}

command -v task >/dev/null 2>&1 && eval "$(task --completion zsh)"

{{- if index $f "mise" }}
# mise must run after every PATH change (OMZ, dotfiles) so managed tools win over system/Cursor paths.
if "{{ .chezmoi.homeDir }}/.local/bin/mise" --version >/dev/null 2>&1; then
  eval "$({{ .chezmoi.homeDir }}/.local/bin/mise activate zsh)"
elif command -v mise >/dev/null 2>&1 && mise --version >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
{{- end }}

# pnpm
export PNPM_HOME="{{ .chezmoi.homeDir }}/.local/share/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME/bin:"*) ;;
  *) export PATH="$PNPM_HOME/bin:$PATH" ;;
esac
# pnpm end
