{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
#!/usr/bin/sh
{{- if index $f "vivid" }}
if command -v vivid >/dev/null 2>&1; then
  export LS_COLORS="$(vivid generate dracula)"
fi
{{- end }}
{{- if eq .chezmoi.os "android" }}
# Clipboard + notifications via termux-api (requires Termux:API app).
clip_copy() {
  if command -v termux-clipboard-set >/dev/null 2>&1; then
    termux-clipboard-set
  fi
}
clip_paste() {
  command -v termux-clipboard-get >/dev/null 2>&1 && termux-clipboard-get
}
notify_user() {
  if command -v termux-toast >/dev/null 2>&1; then
    termux-toast "$1"
  else
    echo "$1"
  fi
}
{{- else if index $f "xclip" }}
clip_copy() { xclip -selection clipboard; }
clip_paste() { xclip -selection clipboard -o; }
notify_user() {
  if command -v notify-send >/dev/null 2>&1; then
    notify-send "$1"
  fi
}
{{- end }}
export TSS_LOG="-level verbose -file $HOME/.tsserver_temp/tsserver.log";
export MANPAGER='less -X';
export EDITOR='nvim';
export WORKON_HOME=$HOME/.virtualenvs
export HISTORY_PATH="$HOME/.local/share/zsh/history";
export BROWSER=/usr/bin/google-chrome-stable
export LIBAVCODEC_VERSION_MAJOR=60
{{- if index $f "diff_so_fancy" }}
export GIT_PAGER="diff-so-fancy"
{{- end }}
# ignore ones with a length greater than 50 -- thanks to https://github.com/Aloxaf
export ZSH_AUTOSUGGEST_HISTORY_IGNORE='?(#c50,)'
GIT_ALIAS=git

# Enable persistent REPL history for `node`.
export NODE_REPL_HISTORY=$HOME/.node_history;
# Allow 32³ entries; the default is 1000.
export NODE_REPL_HISTORY_SIZE='32768';
# Use sloppy mode by default, matching web browsers.
export NODE_REPL_MODE='sloppy';

# Make Python use UTF-8 encoding for output to stdin, stdout, and stderr.
export PYTHONIOENCODING='UTF-8';

# Prefer US English and use UTF-8.
export LANG='en_US.UTF-8';
export LC_ALL='en_US.UTF-8';

export ACLOCAL_FLAGS="-I /opt/gnome/share/aclocal -I /usr/share/aclocal"

export DEBIAN_PREVENT_KEYBOARD_CHANGES=yes

export QT_QPA_PLATFORMTHEME=qt6ct
export LOG_LEVEL=DEBUG
export COLOR_LOGGING=enabled

export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:-1,spinner:#f5e0dc,hl:#f38ba8 \
--color=fg:#cdd6f4,header:#f38ba8,info:#cba6f7,pointer:#f5e0dc \
--color=marker:#f5e0dc,fg+:#cdd6f4,prompt:#cba6f7,hl+:#f38ba8 \
--bind 'tab:down,shift-tab:up'"

export CGO_ENABLED=1
export CXX=clang++ 

# export BIGQUERY_EMULATOR_HOST=https://bigquery.googleapis.com

export TMOUT=0

export PERL5LIB="$HOME/perl5/lib/perl5${PERL5LIB:+:${PERL5LIB}}";
export PERL_LOCAL_LIB_ROOT="$HOME/perl5${PERL_LOCAL_LIB_ROOT:+:${PERL_LOCAL_LIB_ROOT}}";
export PERL_MB_OPT="--install_base \"$HOME/perl5\"";
export PERL_MM_OPT="INSTALL_BASE=$HOME/perl5";

export NVIM_ALIAS="/usr/local/bin/nvim"
export GIT_ALIAS="git"
export nvim_cfg_alias="chezmoi edit -- /usr/local/bin/nvim"
export git_cfg_alias="chezmoi"
