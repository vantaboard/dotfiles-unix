{{ if or (eq .chezmoi.os "linux") (eq .chezmoi.os "android") -}}
{{- $p := .profile_example -}}
{{- if eq .chezmoi.os "android" -}}{{- $p = .profile_termux_example -}}{{- end -}}
{{- if index . "profile" -}}
{{-   if eq .chezmoi.os "android" -}}{{- $p = mergeOverwrite $p .profile -}}
{{-   else -}}{{- $p = .profile -}}
{{-   end -}}
{{- end -}}
{{- if env "CHEZMOI_CI" -}}{{- $p = .profile_ci -}}{{- end -}}
{{- if index . "profile_host" -}}{{- $p = mergeOverwrite $p .profile_host -}}{{- end -}}
{{- if eq .chezmoi.os "android" -}}
{{- $p = mergeOverwrite $p (dict "features" (mergeOverwrite $p.features .profile_termux_example.features)) -}}
{{- end -}}
{{- $f := $p.features -}}
{{- if index $f "diff_so_fancy" -}}
{{ if eq .chezmoi.os "android" -}}
#!{{ joinPath (dir .chezmoi.homeDir) "usr/bin/bash" }}
set -euo pipefail
{{ else -}}
#!/bin/bash
set -euo pipefail
{{ end -}}

# hash: diff-so-fancy-v2

if [[ "${CHEZMOI_CI:-}" == "1" ]]; then
  echo "CHEZMOI_CI=1; skipping diff-so-fancy install"
  exit 0
fi

HOME_DIR="{{ .chezmoi.homeDir }}"
DSF_VERSION="1.4.10"
DSF_BIN="$HOME_DIR/.local/bin/diff-so-fancy"
DSF_URL="https://github.com/so-fancy/diff-so-fancy/releases/download/v${DSF_VERSION}/diff-so-fancy"
LEGACY_REPO="$HOME_DIR/.local/share/diff-so-fancy"

dsf_usable() {
  [[ -x "$DSF_BIN" ]] && head -1 "$DSF_BIN" | grep -q perl
}

if dsf_usable; then
  echo "diff-so-fancy already installed at $DSF_BIN"
  exit 0
fi

if ! command -v perl >/dev/null 2>&1; then
{{- if eq .chezmoi.os "android" }}
  echo "Installing perl (required by diff-so-fancy)..."
  apt install -y perl 2>/dev/null || pkg install -y perl 2>/dev/null || {
    echo "WARN: perl not available; skipping diff-so-fancy install"
    exit 0
  }
{{- else }}
  echo "WARN: perl not found; skipping diff-so-fancy install"
  exit 0
{{- end }}
fi

if ! command -v curl >/dev/null 2>&1; then
  echo "WARN: curl not found; skipping diff-so-fancy install"
  exit 0
fi

mkdir -p "$HOME_DIR/.local/bin"
echo "Installing diff-so-fancy v${DSF_VERSION}..."
curl -fsSL "$DSF_URL" -o "$DSF_BIN"
chmod +x "$DSF_BIN"

if [[ -d "$LEGACY_REPO" ]]; then
  rm -rf "$LEGACY_REPO"
fi

if dsf_usable; then
  echo "diff-so-fancy installed to $DSF_BIN"
else
  echo "WARN: diff-so-fancy install failed"
  rm -f "$DSF_BIN"
  exit 0
fi
{{- end -}}
{{ end -}}
